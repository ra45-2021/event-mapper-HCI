<Page x:Class="WorldEventMapper.Home.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="HomePage"
      Background="#F7F9FC">

    <Page.Resources>
        <SolidColorBrush x:Key="AppBackground" Color="#F7F9FC"/>
        <SolidColorBrush x:Key="PanelBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PanelBackgroundSoft" Color="#EAF2FF"/>
        <SolidColorBrush x:Key="BorderBrushColor" Color="#C7D2E0"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="TextBrush" Color="#1F2937"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#4B5563"/>

        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#C7D2E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="8,4"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="TextInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="54"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#C7D2E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>

        <Style x:Key="ComboInputStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="54"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#C7D2E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>

        <Style x:Key="DateInputStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="54"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="BorderBrush" Value="#C7D2E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>

        <Style x:Key="CheckBoxStyleAccessible" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="#FFFFFF"
                BorderBrush="#C7D2E0"
                BorderThickness="0,0,2,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="120"/>
                    <RowDefinition Height="90"/>
                    <RowDefinition Height="90"/>
                    <RowDefinition Height="90"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        BorderBrush="#C7D2E0"
                        BorderThickness="0,0,0,2"
                        Padding="24">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="58"
                                Height="58"
                                Background="#EAF2FF"
                                CornerRadius="29"
                                BorderBrush="#9DB7E8"
                                BorderThickness="2"
                                Margin="0,0,16,0">
                            <TextBlock Text="🌍"
                                       FontSize="26"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Top"
                                       TextAlignment="Center" Margin="0,8,0,0"/>
                        </Border>

                        <TextBlock VerticalAlignment="Center"
                                   Foreground="#1F2937"
                                   FontWeight="Bold"
                                   FontSize="22"
                                   TextWrapping="Wrap">
                            WORLD EVENT
                            <LineBreak/>
                            MAPPER
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Button Grid.Row="1"
                        Style="{StaticResource RoundedButtonStyle}"
                        Margin="18,14,18,8"
                        Background="#EAF2FF"
                        BorderBrush="#9DB7E8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⌂" Foreground="{StaticResource AccentBrush}" FontSize="20" Margin="0,0,12,0"/>
                        <TextBlock Text="Home" Foreground="#1F2937" FontSize="19"/>
                    </StackPanel>
                </Button>

                <Button Grid.Row="2"
                        Style="{StaticResource RoundedButtonStyle}"
                        Margin="18,8,18,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="☰" Foreground="{StaticResource AccentBrush}" FontSize="20" Margin="0,0,12,0"/>
                        <TextBlock Text="Event List" Foreground="#1F2937" FontSize="19"/>
                    </StackPanel>
                </Button>

                <Button Grid.Row="3"
                        Style="{StaticResource RoundedButtonStyle}"
                        Margin="18,8,18,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🗺" Foreground="{StaticResource AccentBrush}" FontSize="20" Margin="0,0,12,0"/>
                        <TextBlock Text="Event Map" Foreground="#1F2937" FontSize="19"/>
                    </StackPanel>
                </Button>

                <Button Grid.Row="4"
                        VerticalAlignment="Top"
                        Style="{StaticResource RoundedButtonStyle}"
                        Margin="18,8,18,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="?" Foreground="{StaticResource AccentBrush}" FontSize="20" Margin="0,0,12,0"/>
                        <TextBlock Text="Help" Foreground="#1F2937" FontSize="19"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Column="1" Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Home Page"
                           Foreground="#1F2937"
                           FontSize="42"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Width="54"
                            Height="54"
                            Margin="0,0,12,0"
                            Style="{StaticResource RoundedButtonStyle}"
                            Background="#FFFFFF">
                        <TextBlock Text="?" FontSize="20" Foreground="#1F2937" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>

                    <Button Width="54"
                            Height="54"
                            Style="{StaticResource RoundedButtonStyle}"
                            Background="#FFFFFF"
                            Click="CloseToMain_Click">
                        <TextBlock Text="✕" FontSize="18" Foreground="#1F2937" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Top action buttons -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,24">
                <Button Style="{StaticResource RoundedButtonStyle}" Margin="0,0,14,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="⊕" Foreground="{StaticResource AccentBrush}" FontSize="20" Margin="0,0,10,0"/>
                        <TextBlock Text="New Event"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource RoundedButtonStyle}" Margin="0,0,14,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="🗂" Foreground="{StaticResource AccentBrush}" FontSize="20" Margin="0,0,10,0"/>
                        <TextBlock Text="Manage Events"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource RoundedButtonStyle}" Margin="0,0,14,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="🏷" Foreground="{StaticResource AccentBrush}" FontSize="20" Margin="0,0,10,0"/>
                        <TextBlock Text="Manage Tags"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource RoundedButtonStyle}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="✎" Foreground="{StaticResource AccentBrush}" FontSize="20" Margin="0,0,10,0"/>
                        <TextBlock Text="Manage Event Types"/>
                    </StackPanel>
                </Button>
            </UniformGrid>

            <!-- Form -->
            <Border Grid.Row="2"
                    Background="{StaticResource PanelBackground}"
                    BorderBrush="{StaticResource BorderBrushColor}"
                    BorderThickness="2"
                    CornerRadius="20"
                    Padding="28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left form -->
                    <Grid Grid.Column="0" Margin="0,0,8,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,18">
                            <TextBlock Text="Event ID" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Style="{StaticResource TextInputStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,0,0,18">
                            <TextBlock Text="Event Name" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Style="{StaticResource TextInputStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Margin="0,0,0,18">
                            <TextBlock Text="Event Description" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Style="{StaticResource TextInputStyle}"
                                     Height="90"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Margin="0,0,0,18">
                            <TextBlock Text="Event Type" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox Style="{StaticResource ComboInputStyle}">
                                <ComboBoxItem Content="Conference"/>
                                <ComboBoxItem Content="Festival"/>
                                <ComboBoxItem Content="Concert"/>
                                <ComboBoxItem Content="Sport"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Margin="0,0,0,18">
                            <TextBlock Text="Event Attendance" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox Style="{StaticResource ComboInputStyle}">
                                <ComboBoxItem Content="Small"/>
                                <ComboBoxItem Content="Medium"/>
                                <ComboBoxItem Content="Large"/>
                            </ComboBox>
                        </StackPanel>

                        <Grid Grid.Row="5" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Is the Event Humanitarian?" Style="{StaticResource FieldLabelStyle}"/>
                                <CheckBox Style="{StaticResource CheckBoxStyleAccessible}" Content="Yes"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Event Cost" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox Style="{StaticResource TextInputStyle}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- Right form -->
                    <Grid Grid.Column="2" Margin="8,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,18">
                            <TextBlock Text="Event Icon" Style="{StaticResource FieldLabelStyle}"/>
                            <Border Height="130"
                                    Background="#EAF2FF"
                                    BorderBrush="#9DB7E8"
                                    BorderThickness="2"
                                    CornerRadius="12">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="🖼" FontSize="30" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Drag and drop files here"
                                               Foreground="#374151"
                                               FontSize="17"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,0,0,18">
                            <TextBlock Text="Event Past Performing Years" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Style="{StaticResource TextInputStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Margin="0,0,0,18">
                            <TextBlock Text="Event Upcoming Date" Style="{StaticResource FieldLabelStyle}"/>
                            <DatePicker Style="{StaticResource DateInputStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3" Margin="0,0,0,18">
                            <TextBlock Text="Event Location" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox Style="{StaticResource ComboInputStyle}">
                                <ComboBoxItem Content="Serbia"/>
                                <ComboBoxItem Content="Germany"/>
                                <ComboBoxItem Content="France"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Margin="0,0,0,18">
                            <TextBlock Text="Event Tags" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox Style="{StaticResource ComboInputStyle}">
                                <ComboBoxItem Content="Music"/>
                                <ComboBoxItem Content="Culture"/>
                                <ComboBoxItem Content="Education"/>
                            </ComboBox>
                        </StackPanel>

                        <Button Grid.Row="5"
                                Content="Save"
                                Width="170"
                                Height="60"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Margin="0,24,0,0"
                                Style="{StaticResource RoundedButtonStyle}"
                                Background="#2563EB"
                                Foreground="White"
                                BorderBrush="#2563EB"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>