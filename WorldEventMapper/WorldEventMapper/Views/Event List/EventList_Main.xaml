<Window x:Class="WorldEventMapper.Event_List.EventList_Main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="Event List"
        Height="900"
        Width="1250"
        WindowStartupLocation="CenterScreen"
        Background="#F7F9FC"
        WindowState="Maximized"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackground"
                         Color="#F3F6FB" />
        <SolidColorBrush x:Key="PanelBackground"
                         Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushColor"
                         Color="#D6DFEA" />
        <SolidColorBrush x:Key="AccentBrush"
                         Color="#0E7EEC" />
        <SolidColorBrush x:Key="TextBrush"
                         Color="#0F172A" />
        <SolidColorBrush x:Key="MutedTextBrush"
                         Color="#6B7280" />

        <Style x:Key="NavButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderBrush"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="18,0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="FontSize"
                    Value="18" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Height"
                    Value="58" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#EEF6FF" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#E0F0FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActiveNavButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background"
                    Value="#EAF2FF" />
            <Setter Property="BorderBrush"
                    Value="#D6E8FF" />
            <Setter Property="BorderThickness"
                    Value="1" />
        </Style>

        <Style x:Key="TopHelpButtonStyle"
               TargetType="Button">
            <Setter Property="Width"
                    Value="120" />
            <Setter Property="Height"
                    Value="54" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                CornerRadius="12"
                                Padding="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#EEF6FF" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#E0F0FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButtonStyle"
               TargetType="Button">
            <Setter Property="Width"
                    Value="52" />
            <Setter Property="Height"
                    Value="52" />
            <Setter Property="Background"
                    Value="#FFFFFF" />
            <Setter Property="BorderBrush"
                    Value="#D6DFEA" />
            <Setter Property="BorderThickness"
                    Value="1.5" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#EEF6FF" />
                                <Setter TargetName="Bd"
                                        Property="BorderBrush"
                                        Value="#BFDFFF" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#E0F0FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Height"
                    Value="52" />
            <Setter Property="Background"
                    Value="#FFFFFF" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderBrush"
                    Value="#C7D2E0" />
            <Setter Property="BorderThickness"
                    Value="1.5" />
            <Setter Property="Padding"
                    Value="14,12" />
            <Setter Property="FontSize"
                    Value="16" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
        </Style>

        <Style x:Key="EventDataGridStyle"
               TargetType="DataGrid">
            <Setter Property="Background"
                    Value="#FFFFFF" />
            <Setter Property="BorderBrush"
                    Value="#D6DFEA" />
            <Setter Property="BorderThickness"
                    Value="1.5" />
            <Setter Property="GridLinesVisibility"
                    Value="All" />
            <Setter Property="HorizontalGridLinesBrush"
                    Value="#E5ECF5" />
            <Setter Property="VerticalGridLinesBrush"
                    Value="#E5ECF5" />
            <Setter Property="RowHeight"
                    Value="44" />
            <Setter Property="HeadersVisibility"
                    Value="Column" />
            <Setter Property="FontSize"
                    Value="14" />
            <Setter Property="CanUserAddRows"
                    Value="False" />
            <Setter Property="CanUserDeleteRows"
                    Value="False" />
            <Setter Property="AutoGenerateColumns"
                    Value="False" />
            <Setter Property="SelectionMode"
                    Value="Single" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="0,0,1.5,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="138" />
                    <RowDefinition Height="70" />
                    <RowDefinition Height="70" />
                    <RowDefinition Height="70" />
                    <RowDefinition Height="70" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="80" />
                </Grid.RowDefinitions>

                <!-- Logo -->
                <Border Grid.Row="0"
                        BorderBrush="#E5ECF5"
                        BorderThickness="0,0,0,1"
                        Padding="0">

                    <Button Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Home_Click"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">

                        <Grid HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch">

                            <Border Width="720"
                                    Height="720"
                                    Background="White"
                                    CornerRadius="36"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                                <Image Source="/Assets/logo.png"
                                       Width="200"
                                       Height="200"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>
                        </Grid>
                    </Button>
                </Border>

                <!-- Home -->
                <Button Grid.Row="1"
                        Style="{StaticResource NavButtonStyle}"
                        Margin="18,10,18,0"
                        Click="Home_Click">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="Home"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        VerticalAlignment="Center"
                                        Margin="-20,0,0,0" />

                        <TextBlock Grid.Column="1"
                                   Text="Home"
                                   Foreground="#1F2937"
                                   FontSize="19"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <!-- Event List active -->
                <Button Grid.Row="2"
                        Style="{StaticResource ActiveNavButtonStyle}"
                        Margin="18,8,18,0">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="List"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        VerticalAlignment="Center"
                                        Margin="-20,5,0,0" />

                        <TextBlock Grid.Column="1"
                                   Text="Event List"
                                   Foreground="#1F2937"
                                   FontSize="19"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <!-- Event Management -->
                <Button Grid.Row="3"
                        Style="{StaticResource NavButtonStyle}"
                        Margin="18,8,18,0"
                        Click="EventManagement_Click">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="Edit"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        VerticalAlignment="Center"
                                        Margin="-20,5,0,0" />

                        <TextBlock Grid.Column="1"
                                   Text="Event Management"
                                   Foreground="#1F2937"
                                   FontSize="18"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <!-- Help -->
                <Button Grid.Row="4"
                        Style="{StaticResource NavButtonStyle}"
                        Margin="18,8,18,0"
                        Click="Help_Click">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="QuestionCircle"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        VerticalAlignment="Center"
                                        Margin="-20,5,0,0" />

                        <TextBlock Grid.Column="1"
                                   Text="Help"
                                   Foreground="#1F2937"
                                   FontSize="19"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <!-- Logout button -->
                <Button Grid.Row="6"
                        Style="{StaticResource NavButtonStyle}"
                        Height="58"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        Margin="18,0,18,0"
                        Click="CloseToMain_Click">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="SignOut"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        VerticalAlignment="Center"
                                        Margin="-20,5,0,0" />

                        <TextBlock Grid.Column="1"
                                   Text="Logout"
                                   Foreground="#1F2937"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Column="1"
              Margin="32,20,32,32">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Event List"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="42"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />

                <Button Grid.Column="1"
                        Style="{StaticResource TopHelpButtonStyle}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                        <Border Width="42"
                                Height="42"
                                Background="#0E7EEC"
                                CornerRadius="21"
                                Margin="0,0,6,0">

                            <TextBlock Text="?"
                                       Foreground="White"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Text="Help"
                                   Foreground="#0E7EEC"
                                   FontSize="19"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Search and filter row -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="340" />
                </Grid.ColumnDefinitions>

                <!-- Search all fields -->
                <Border Grid.Column="0"
                        Background="#FFFFFF"
                        BorderBrush="#D6DFEA"
                        BorderThickness="1.5"
                        CornerRadius="16"
                        Padding="16">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Style="{StaticResource IconButtonStyle}">
                            <fa:FontAwesome Icon="PlusCircle"
                                            Foreground="#0E7EEC"
                                            FontSize="28"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                        </Button>

                        <StackPanel Grid.Column="1"
                                    Margin="12,0,0,0">
                            <TextBlock Text="Search events"
                                       Foreground="#1F2937"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8" />

                            <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                     Text="{Binding EventSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Search by ID, name, description, type, attendance, cost, location, years, date or tags" />
                        </StackPanel>

                        <Button Grid.Column="2"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                VerticalAlignment="Bottom"
                                Height="52">
                            <TextBlock Text="×"
                                       FontSize="24"
                                       Foreground="#1F2937"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>
                    </Grid>
                </Border>

                <!-- Filter list -->
                <Border Grid.Column="2"
                        Background="#FFFFFF"
                        BorderBrush="#D6DFEA"
                        BorderThickness="1.5"
                        CornerRadius="16"
                        Padding="16">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Style="{StaticResource IconButtonStyle}">
                            <fa:FontAwesome Icon="Filter"
                                            Foreground="#0E7EEC"
                                            FontSize="28"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                        </Button>

                        <StackPanel Grid.Column="1"
                                    Margin="12,0,0,0">
                            <TextBlock Text="Filter list"
                                       Foreground="#1F2937"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8" />

                            <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                     Text="{Binding EventSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Filter the event table in real time" />
                        </StackPanel>

                        <Button Grid.Column="2"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                VerticalAlignment="Bottom"
                                Height="52">
                            <TextBlock Text="×"
                                       FontSize="24"
                                       Foreground="#1F2937"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <!-- Event table -->
            <Border Grid.Row="4"
                    Background="#FFFFFF"
                    BorderBrush="#D6DFEA"
                    BorderThickness="1.5"
                    CornerRadius="16"
                    Padding="12">

                <DataGrid Style="{StaticResource EventDataGridStyle}"
                          ItemsSource="{Binding EventsView}"
                          SelectedItem="{Binding SelectedEvent}">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding ID}"
                                            Width="80" />
                        <DataGridTextColumn Header="Name"
                                            Binding="{Binding Name}"
                                            Width="160" />
                        <DataGridTextColumn Header="Description"
                                            Binding="{Binding Description}"
                                            Width="220" />
                        <DataGridTextColumn Header="Type"
                                            Binding="{Binding EventTypeId}"
                                            Width="100" />
                        <DataGridTextColumn Header="Attendance"
                                            Binding="{Binding Attendance}"
                                            Width="130" />
                        <DataGridCheckBoxColumn Header="Humanitarian"
                                                Binding="{Binding IsHumanitarian}"
                                                Width="120" />
                        <DataGridTextColumn Header="Cost ($)"
                                            Binding="{Binding Cost}"
                                            Width="100" />
                        <DataGridTextColumn Header="Location"
                                            Binding="{Binding Location}"
                                            Width="170" />
                        <DataGridTextColumn Header="Upcoming Date"
                                            Binding="{Binding UpcomingDate, StringFormat=d}"
                                            Width="130" />
                        <DataGridTextColumn Header="Icon"
                                            Binding="{Binding IconPath}"
                                            Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Window>