<Window x:Class="WorldEventMapper.Events.Events_Main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:converters="clr-namespace:WorldEventMapper"
        Title="Events"
        Height="900"
        Width="1250"
        WindowStartupLocation="CenterScreen"
        Background="#F7F9FC"
        WindowState="Maximized"
        ResizeMode="NoResize">

    <Window.Resources>

        <converters:ImagePathConverter x:Key="ImagePathConverter" />
        
        <SolidColorBrush x:Key="AppBackground"
                         Color="#F3F6FB" />
        <SolidColorBrush x:Key="PanelBackground"
                         Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushColor"
                         Color="#D6DFEA" />
        <SolidColorBrush x:Key="AccentBrush"
                         Color="#0E7EEC" />
        <SolidColorBrush x:Key="TextBrush"
                         Color="#0F172A" />
        <SolidColorBrush x:Key="MutedTextBrush"
                         Color="#6B7280" />

        <Style x:Key="NavButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderBrush"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="18,0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="FontSize"
                    Value="18" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Height"
                    Value="58" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#EEF6FF" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#E0F0FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActiveNavButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background"
                    Value="#EAF2FF" />
            <Setter Property="BorderBrush"
                    Value="#D6E8FF" />
            <Setter Property="BorderThickness"
                    Value="1" />
        </Style>

        <Style x:Key="TableViewButtonStyle"
               TargetType="Button">
            <Setter Property="Height"
                    Value="38" />
            <Setter Property="Background"
                    Value="#FFFFFF" />
            <Setter Property="Foreground"
                    Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush"
                    Value="#D6DFEA" />
            <Setter Property="BorderThickness"
                    Value="1.2" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="FontSize"
                    Value="15" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="10,0">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#EEF6FF" />

                                <Setter TargetName="Bd"
                                        Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#E0F0FF" />
                            </Trigger>
                            

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TableEditButtonStyle"
               TargetType="Button">
            <Setter Property="Height"
                    Value="38" />
            <Setter Property="Foreground"
                    Value="#FFFFFF" />
            <Setter Property="Background"
                    Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush"
                    Value="#D6DFEA" />
            <Setter Property="BorderThickness"
                    Value="1.2" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="FontSize"
                    Value="15" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="10,0">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#02419E" />

                                <Setter TargetName="Bd"
                                        Property="BorderBrush"
                                        Value="#002C6B" />
                                
                                <Setter TargetName="Bd"
                                        Property="BorderThickness"
                                        Value="1.9" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#E0F0FF" />
                            </Trigger>


                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TableDeleteButtonStyle"
               TargetType="Button">
            <Setter Property="Height"
                    Value="38" />
            <Setter Property="Background"
                    Value="#FFFFFF" />
            <Setter Property="Foreground"
                    Value="#D10000" />
            <Setter Property="BorderBrush"
                    Value="#D6DFEA" />
            <Setter Property="BorderThickness"
                    Value="1.2" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="FontSize"
                    Value="15" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="10,0">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#EBD3D3" />
                                
                                <Setter TargetName="Bd"
                                        Property="BorderBrush"
                                        Value="#8F1D1D" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#E0F0FF" />
                            </Trigger>


                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernScrollBarThumbStyle"
               TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#CBD5E1"
                                CornerRadius="8" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="#94A3B8" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernScrollBarStyle"
               TargetType="ScrollBar">
            <Setter Property="Width"
                    Value="10" />

            <Setter Property="Background"
                    Value="Transparent" />

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="ScrollBar">

                        <Grid Background="Transparent">

                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">

                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineUpCommand"
                                                  Opacity="0"
                                                  IsTabStop="False" />
                                </Track.DecreaseRepeatButton>

                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ModernScrollBarThumbStyle}" />
                                </Track.Thumb>

                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineDownCommand"
                                                  Opacity="0"
                                                  IsTabStop="False" />
                                </Track.IncreaseRepeatButton>

                            </Track>

                        </Grid>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernScrollBarStyleMini"
               TargetType="ScrollBar">
            <Setter Property="Width"
                    Value="3" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0"
                                                  IsHitTestVisible="False" />
                                </Track.DecreaseRepeatButton>

                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#AFC3DA"
                                                        CornerRadius="2"
                                                        Margin="5,0,4,0" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>

                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0"
                                                  IsHitTestVisible="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style x:Key="PrimaryActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource TableActionButtonStyle}">
            <Setter Property="Background"
                    Value="#0E7EEC" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#0E7EEC" />
        </Style>

        <Style x:Key="TopHelpButtonStyle"
               TargetType="Button">
            <Setter Property="Width"
                    Value="120" />
            <Setter Property="Height"
                    Value="54" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                CornerRadius="12"
                                Padding="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#EEF6FF" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#E0F0FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopBarButtonStyle"
               TargetType="Button">

            <Setter Property="Height"
                    Value="54" />

            <Setter Property="Background"
                    Value="#FFFFFF" />

            <Setter Property="BorderBrush"
                    Value="#D6DFEA" />

            <Setter Property="BorderThickness"
                    Value="1.2" />

            <Setter Property="Cursor"
                    Value="Hand" />

            <Setter Property="Padding"
                    Value="12,0" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">

                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#EEF6FF" />

                                <Setter TargetName="Bd"
                                        Property="BorderBrush"
                                        Value="#D6E8FF" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#E0F0FF" />
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TopBarTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Height"
                    Value="54" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="FontSize"
                    Value="16" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Padding"
                    Value="4,0,34,0" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
        </Style>

        <Style x:Key="IconButtonStyle"
               TargetType="Button">
            <Setter Property="Width"
                    Value="52" />
            <Setter Property="Height"
                    Value="52" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderBrush"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#EEF6FF" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#E0F0FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TextOnlyButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="FontSize"
                    Value="18" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#EEF6FF" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#E0F0FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SearchTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Height"
                    Value="50" />
            <Setter Property="Background"
                    Value="#FFFFFF" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderBrush"
                    Value="#C7D2E0" />
            <Setter Property="BorderThickness"
                    Value="2" />
            <Setter Property="Padding"
                    Value="14,0,48,0" />
            <Setter Property="FontSize"
                    Value="16" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="MainBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">

                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="0,0,4,0"
                                          VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="MainBorder"
                                        Property="BorderBrush"
                                        Value="#9DB7E8" />
                            </Trigger>

                            <Trigger Property="IsKeyboardFocused"
                                     Value="True">
                                <Setter TargetName="MainBorder"
                                        Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabelStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="FontSize"
                    Value="15" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Margin"
                    Value="0,0,0,6" />
        </Style>

        <Style x:Key="PlaceholderBaseStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="#9CA3AF" />
            <Setter Property="FontSize"
                    Value="16" />
            <Setter Property="Margin"
                    Value="16,0,48,0" />
            <Setter Property="VerticalAlignment"
                    Value="Center" />
            <Setter Property="IsHitTestVisible"
                    Value="False" />
        </Style>

        <Style x:Key="PopupComboBoxStyle"
               TargetType="ComboBox">
            <Setter Property="Height"
                    Value="50" />
            <Setter Property="FontSize"
                    Value="16" />
            <Setter Property="Background"
                    Value="#FFFFFF" />
            <Setter Property="BorderBrush"
                    Value="#C7D2E0" />
            <Setter Property="BorderThickness"
                    Value="1.5" />
            <Setter Property="Padding"
                    Value="12,8" />
        </Style>

        <Style x:Key="EventDataGridStyle"
               TargetType="DataGrid">
            <Setter Property="Background"
                    Value="#FFFFFF" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="GridLinesVisibility"
                    Value="None" />
            <Setter Property="RowHeight"
                    Value="66" />
            <Setter Property="HeadersVisibility"
                    Value="Column" />
            <Setter Property="CanUserSortColumns"
                    Value="True" />
            <Setter Property="FontSize"
                    Value="14" />
            <Setter Property="FontFamily"
                    Value="Segoe UI" />
            <Setter Property="CanUserAddRows"
                    Value="False" />
            <Setter Property="CanUserDeleteRows"
                    Value="False" />
            <Setter Property="AutoGenerateColumns"
                    Value="False" />
            <Setter Property="SelectionMode"
                    Value="Single" />
            <Setter Property="SelectionUnit"
                    Value="FullRow" />
            <Setter Property="RowBackground"
                    Value="#FFFFFF" />
            <Setter Property="AlternatingRowBackground"
                    Value="#F9FBFD" />
            <Setter Property="HorizontalScrollBarVisibility"
                    Value="Auto" />
            <Setter Property="VerticalScrollBarVisibility"
                    Value="Auto" />

            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background"
                                Value="#E0F2FE" />
                        <Setter Property="Foreground"
                                Value="#475569" />
                        <Setter Property="FontSize"
                                Value="15" />
                        <Setter Property="FontWeight"
                                Value="SemiBold" />
                        <Setter Property="Padding"
                                Value="16" />
                        <Setter Property="BorderThickness"
                                Value="0,0,0,1" />
                        <Setter Property="BorderBrush"
                                Value="#E2E8F0" />
                        <Setter Property="HorizontalContentAlignment"
                                Value="Left" />
                        <Setter Property="VerticalContentAlignment"
                                Value="Center" />
                    </Style>
                </Setter.Value>
            </Setter>

            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow">
                        <Setter Property="BorderThickness"
                                Value="0,0,0,1" />
                        <Setter Property="BorderBrush"
                                Value="#EEF2F7" />
                        <Setter Property="Cursor"
                                Value="Hand" />

                        <Style.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#F0F7FF" />
                            </Trigger>

                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#E0F2FE" />
                                <Setter Property="Foreground"
                                        Value="#0F172A" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>

            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding"
                                Value="16,8" />
                        <Setter Property="BorderThickness"
                                Value="0" />
                        <Setter Property="Foreground"
                                Value="#334155" />
                        <Setter Property="FontSize"
                                Value="15" />
                        <Setter Property="VerticalContentAlignment"
                                Value="Center" />
                        <Setter Property="HorizontalContentAlignment"
                                Value="Left" />
                        <Setter Property="FocusVisualStyle"
                                Value="{x:Null}" />
                        <Setter Property="TextBlock.VerticalAlignment"
                                Value="Center" />

                        <Style.Triggers>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="Transparent" />
                                <Setter Property="Foreground"
                                        Value="#0F172A" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="0,0,1.5,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="138" />
                    <RowDefinition Height="70" />
                    <RowDefinition Height="70" />
                    <RowDefinition Height="70" />
                    <RowDefinition Height="70" />
                    <RowDefinition Height="70" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="80" />
                </Grid.RowDefinitions>

                <!-- Logo -->
                <Border Grid.Row="0"
                        BorderBrush="#E5ECF5"
                        BorderThickness="0,0,0,1"
                        Padding="0">

                    <Button Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Home_Click"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">

                        <Grid HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch">

                            <Border Width="720"
                                    Height="720"
                                    Background="White"
                                    CornerRadius="36"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                                <Image Source="/Assets/logo.png"
                                       Width="200"
                                       Height="200"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>
                        </Grid>
                    </Button>
                </Border>

                <!-- Home -->
                <Button Grid.Row="1"
                        Style="{StaticResource NavButtonStyle}"
                        Margin="18,10,18,0"
                        Click="Home_Click">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="Home"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        VerticalAlignment="Center"
                                        Margin="-20,0,0,0" />

                        <TextBlock Grid.Column="1"
                                   Text="Home"
                                   Foreground="#1F2937"
                                   FontSize="19"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <!-- Events ACTIVE -->
                <Button Grid.Row="2"
                        Style="{StaticResource ActiveNavButtonStyle}"
                        Margin="18,8,18,0">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="Calendar"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        VerticalAlignment="Center"
                                        Margin="-20,5,0,0" />

                        <TextBlock Grid.Column="1"
                                   Text="Events"
                                   Foreground="#1F2937"
                                   FontSize="19"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <!-- Event Types -->
                <Button Grid.Row="3"
                        Style="{StaticResource NavButtonStyle}"
                        Margin="18,8,18,0"
                        Click="EventTypes_Click">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="Clone"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        VerticalAlignment="Center"
                                        Margin="-20,5,0,0" />

                        <TextBlock Grid.Column="1"
                                   Text="Event Types"
                                   Foreground="#1F2937"
                                   FontSize="18"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <!-- Event Tags -->
                <Button Grid.Row="4"
                        Style="{StaticResource NavButtonStyle}"
                        Margin="18,8,18,0"
                        Click="EventTags_Click">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="Tag"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        VerticalAlignment="Center"
                                        Margin="-20,5,0,0" />

                        <TextBlock Grid.Column="1"
                                   Text="Event Tags"
                                   Foreground="#1F2937"
                                   FontSize="18"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <!-- Help -->
                <Button Grid.Row="5"
                        Style="{StaticResource NavButtonStyle}"
                        Margin="18,8,18,0"
                        Click="Help_Click">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="QuestionCircle"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        VerticalAlignment="Center"
                                        Margin="-20,5,0,0" />

                        <TextBlock Grid.Column="1"
                                   Text="Help"
                                   Foreground="#1F2937"
                                   FontSize="19"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <!-- Exit -->
                <Button Grid.Row="7"
                        Style="{StaticResource NavButtonStyle}"
                        Height="58"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        Margin="18,0,18,0"
                        Click="CloseToMain_Click">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="SignOut"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        VerticalAlignment="Center"
                                        Margin="-20,5,0,0" />

                        <TextBlock Grid.Column="1"
                                   Text="Exit"
                                   Foreground="#1F2937"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Column="1"
              Margin="32,20,32,32">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Events"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="42"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />

                <Button Grid.Column="1"
                        Style="{StaticResource TopHelpButtonStyle}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="Help_Click">

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                        <Border Width="42"
                                Height="42"
                                Background="#0E7EEC"
                                CornerRadius="21"
                                Margin="0,0,6,0">

                            <TextBlock Text="?"
                                       Foreground="White"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Text="Help"
                                   Foreground="#0E7EEC"
                                   FontSize="19"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Search / filter row -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="208" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>

                <!-- New Event -->
                <Button Grid.Column="0"
                        Height="54"
                        Width="210"
                        HorizontalAlignment="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="NewEvent_Click"
                        Margin="-30,0,0,-5">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">

                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="14">

                                <Grid HorizontalAlignment="Center"
                                      VerticalAlignment="Center">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="38" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <fa:FontAwesome x:Name="NewEventIcon"
                                                    Grid.Column="0"
                                                    Icon="PlusCircle"
                                                    Foreground="{StaticResource AccentBrush}"
                                                    FontSize="30"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />

                                    <TextBlock x:Name="NewEventText"
                                               Grid.Column="1"
                                               Text="New Event"
                                               Foreground="#1F2937"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,1" />

                                </Grid>

                            </Border>

                            <ControlTemplate.Triggers>

                                <Trigger Property="IsMouseOver"
                                         Value="True">

                                    <Setter TargetName="NewEventText"
                                            Property="Foreground"
                                            Value="{StaticResource AccentBrush}" />

                                </Trigger>

                            </ControlTemplate.Triggers>

                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Advanced Search -->
                <Border x:Name="AdvancedSearchBorder"
                        Grid.Column="2"
                        Height="54"
                        Background="#FFFFFF"
                        BorderBrush="#C7D2E0"
                        BorderThickness="1.5"
                        CornerRadius="14"
                        MouseEnter="AdvancedSearchBorder_MouseEnter"
                        MouseLeave="AdvancedSearchBorder_MouseLeave">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="OpenSearchPopupButton"
                                Grid.Column="0"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="OpenSearchPopup_Click">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <fa:FontAwesome Icon="Search"
                                            Foreground="{StaticResource AccentBrush}"
                                            FontSize="27"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                        </Button>

                        <Button Grid.Column="1"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                HorizontalContentAlignment="Left"
                                Click="OpenSearchPopup_Click">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>

                            <TextBlock Text="Search Events"
                                       Foreground="#1F2937"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="0,1,8,0" />
                        </Button>

                        <Button x:Name="ClearAdvancedSearchButton"
                                Grid.Column="2"
                                Width="32"
                                Height="32"
                                Visibility="Collapsed"
                                Cursor="Hand"
                                Click="ClearAdvancedSearch_Click">

                            <Button.Style>
                                <Style TargetType="Button">

                                    <Setter Property="Foreground"
                                            Value="#6B7280" />

                                    <Setter Property="Background"
                                            Value="Transparent" />

                                    <Setter Property="BorderBrush"
                                            Value="Transparent" />

                                    <Setter Property="BorderThickness"
                                            Value="0" />

                                    <Setter Property="Template">
                                        <Setter.Value>

                                            <ControlTemplate TargetType="Button">

                                                <Border x:Name="Bd"
                                                        Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>

                                                <ControlTemplate.Triggers>

                                                    <Trigger Property="IsMouseOver"
                                                             Value="True">

                                                        <Setter Property="Foreground"
                                                                Value="#02419E" />

                                                    </Trigger>

                                                </ControlTemplate.Triggers>

                                            </ControlTemplate>

                                        </Setter.Value>
                                    </Setter>

                                </Style>
                            </Button.Style>

                            <TextBlock Text="×"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       FontSize="26"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="-10,-1,0,0" />
                        </Button>

                        <Popup x:Name="AdvancedSearchPopup"
                               PlacementTarget="{Binding ElementName=AdvancedSearchBorder}"
                               Placement="Bottom"
                               HorizontalOffset="0"
                               VerticalOffset="11"
                               AllowsTransparency="True"
                               StaysOpen="False"
                               PopupAnimation="Fade">

                            <Border Width="456"
                                    MaxHeight="650"
                                    Background="#FFFFFF"
                                    BorderBrush="#D6DFEA"
                                    BorderThickness="1"
                                    CornerRadius="15"
                                    Padding="26"
                                    SnapsToDevicePixels="True">

                                <Border.Effect>
                                    <DropShadowEffect Color="#0F172A"
                                                      BlurRadius="28"
                                                      ShadowDepth="6"
                                                      Opacity="0.18" />
                                </Border.Effect>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="18" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="18" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Popup title -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>

                                            <TextBlock Text="Fill one or more fields, then click Search."
                                                       Foreground="#0F172A"
                                                       FontSize="14"
                                                       Margin="0,4,0,0"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Width="42"
                                                Height="42"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Click="CloseSearchPopup_Click">

                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd"
                                                            Background="Transparent"
                                                            CornerRadius="10">

                                                        <fa:FontAwesome Icon="Times"
                                                                        Foreground="#1F2937"
                                                                        FontSize="22"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center" />
                                                    </Border>

                                                    <ControlTemplate.Triggers>

                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                            <Setter TargetName="Bd"
                                                                    Property="Background"
                                                                    Value="#D6DFEA" />
                                                        </Trigger>

                                                        <Trigger Property="IsPressed"
                                                                 Value="True">
                                                            <Setter TargetName="Bd"
                                                                    Property="Background"
                                                                    Value="#D6DFEA" />
                                                        </Trigger>

                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>

                                    <!-- Search fields -->
                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="30" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="14" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="14" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="14" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="14" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="14" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Event ID -->
                                        <StackPanel Grid.Row="0"
                                                    Grid.Column="0">
                                            <TextBlock Text="Event ID"
                                                       Style="{StaticResource FieldLabelStyle}" />
                                            <Grid>
                                                <TextBox x:Name="SearchIdBox"
                                                         Style="{StaticResource SearchTextBoxStyle}"
                                                         Text="{Binding SearchId, UpdateSourceTrigger=Explicit}" />

                                                <TextBlock Text="Example: FI001">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock"
                                                               BasedOn="{StaticResource PlaceholderBaseStyle}">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, ElementName=SearchIdBox}"
                                                                             Value="">
                                                                    <Setter Property="Visibility"
                                                                            Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <Button Width="34"
                                                        Height="34"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0"
                                                        Style="{StaticResource TextOnlyButtonStyle}"
                                                        Click="ClearSearchId_Click">
                                                    <TextBlock Text="×"
                                                               FontSize="22" />
                                                </Button>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Cost -->
                                        <StackPanel Grid.Row="0"
                                                    Grid.Column="2">
                                            <TextBlock Text="Cost"
                                                       Style="{StaticResource FieldLabelStyle}" />
                                            <Grid>
                                                <TextBox x:Name="SearchCostBox"
                                                         Style="{StaticResource SearchTextBoxStyle}"
                                                         Text="{Binding SearchCost, UpdateSourceTrigger=Explicit}" />

                                                <TextBlock Text="Example: 25000">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock"
                                                               BasedOn="{StaticResource PlaceholderBaseStyle}">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, ElementName=SearchCostBox}"
                                                                             Value="">
                                                                    <Setter Property="Visibility"
                                                                            Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <Button Width="34"
                                                        Height="34"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0"
                                                        Style="{StaticResource TextOnlyButtonStyle}"
                                                        Click="ClearSearchCost_Click">
                                                    <TextBlock Text="×"
                                                               FontSize="22" />
                                                </Button>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Name -->
                                        <StackPanel Grid.Row="2"
                                                    Grid.Column="0">
                                            <TextBlock Text="Name"
                                                       Style="{StaticResource FieldLabelStyle}" />
                                            <Grid>
                                                <TextBox x:Name="SearchNameBox"
                                                         Style="{StaticResource SearchTextBoxStyle}"
                                                         Text="{Binding SearchName, UpdateSourceTrigger=Explicit}" />

                                                <TextBlock Text="Example: Kustendorf">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock"
                                                               BasedOn="{StaticResource PlaceholderBaseStyle}">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, ElementName=SearchNameBox}"
                                                                             Value="">
                                                                    <Setter Property="Visibility"
                                                                            Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <Button Width="34"
                                                        Height="34"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0"
                                                        Style="{StaticResource TextOnlyButtonStyle}"
                                                        Click="ClearSearchName_Click">
                                                    <TextBlock Text="×"
                                                               FontSize="22" />
                                                </Button>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Location -->
                                        <StackPanel Grid.Row="2"
                                                    Grid.Column="2">
                                            <TextBlock Text="Location"
                                                       Style="{StaticResource FieldLabelStyle}" />
                                            <Grid>
                                                <TextBox x:Name="SearchLocationBox"
                                                         Style="{StaticResource SearchTextBoxStyle}"
                                                         Text="{Binding SearchLocation, UpdateSourceTrigger=Explicit}" />

                                                <TextBlock Text="Example: Vienna, Austria">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock"
                                                               BasedOn="{StaticResource PlaceholderBaseStyle}">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, ElementName=SearchLocationBox}"
                                                                             Value="">
                                                                    <Setter Property="Visibility"
                                                                            Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <Button Width="34"
                                                        Height="34"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0"
                                                        Style="{StaticResource TextOnlyButtonStyle}"
                                                        Click="ClearSearchLocation_Click">
                                                    <TextBlock Text="×"
                                                               FontSize="22" />
                                                </Button>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Description -->
                                        <StackPanel Grid.Row="4"
                                                    Grid.Column="0">
                                            <TextBlock Text="Description"
                                                       Style="{StaticResource FieldLabelStyle}" />
                                            <Grid>
                                                <TextBox x:Name="SearchDescriptionBox"
                                                         Style="{StaticResource SearchTextBoxStyle}"
                                                         Text="{Binding SearchDescription, UpdateSourceTrigger=Explicit}" />

                                                <TextBlock Text="Example: film festival">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock"
                                                               BasedOn="{StaticResource PlaceholderBaseStyle}">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, ElementName=SearchDescriptionBox}"
                                                                             Value="">
                                                                    <Setter Property="Visibility"
                                                                            Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <Button Width="34"
                                                        Height="34"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0"
                                                        Style="{StaticResource TextOnlyButtonStyle}"
                                                        Click="ClearSearchDescription_Click">
                                                    <TextBlock Text="×"
                                                               FontSize="22" />
                                                </Button>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Past Performing Years -->
                                        <StackPanel Grid.Row="4"
                                                    Grid.Column="2">
                                            <TextBlock Text="Past Performing Years"
                                                       Style="{StaticResource FieldLabelStyle}" />
                                            <Grid>
                                                <TextBox x:Name="SearchPastYearsBox"
                                                         Style="{StaticResource SearchTextBoxStyle}"
                                                         Text="{Binding SearchPastYears, UpdateSourceTrigger=Explicit}" />

                                                <TextBlock Text="Example: 2020, 2021">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock"
                                                               BasedOn="{StaticResource PlaceholderBaseStyle}">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, ElementName=SearchPastYearsBox}"
                                                                             Value="">
                                                                    <Setter Property="Visibility"
                                                                            Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <Button Width="34"
                                                        Height="34"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0"
                                                        Style="{StaticResource TextOnlyButtonStyle}"
                                                        Click="ClearSearchPastYears_Click">
                                                    <TextBlock Text="×"
                                                               FontSize="22" />
                                                </Button>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Event Type -->
                                        <StackPanel Grid.Row="6"
                                                    Grid.Column="0">
                                            <TextBlock Text="Event Type"
                                                       Style="{StaticResource FieldLabelStyle}" />
                                            <Grid>
                                                <ComboBox x:Name="SearchEventTypeBox"
                                                          Style="{StaticResource PopupComboBoxStyle}"
                                                          SelectedValue="{Binding SearchEventTypeId, UpdateSourceTrigger=Explicit}"
                                                          SelectedValuePath="ID"
                                                          DisplayMemberPath="Name"
                                                          ItemsSource="{Binding EventTypes}" />

                                                <Button Width="34"
                                                        Height="34"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0"
                                                        Style="{StaticResource TextOnlyButtonStyle}"
                                                        Click="ClearSearchEventType_Click">
                                                    <TextBlock Text="×"
                                                               FontSize="22" />
                                                </Button>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Upcoming Date -->
                                        <StackPanel Grid.Row="6"
                                                    Grid.Column="2">
                                            <TextBlock Text="Upcoming Date"
                                                       Style="{StaticResource FieldLabelStyle}" />
                                            <Grid>
                                                <DatePicker x:Name="SearchUpcomingDateBox"
                                                            Height="50"
                                                            FontSize="16"
                                                            BorderBrush="#C7D2E0"
                                                            BorderThickness="1.5"
                                                            SelectedDate="{Binding SearchUpcomingDate, UpdateSourceTrigger=Explicit}" />

                                                <Button Width="34"
                                                        Height="34"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,36,0"
                                                        Style="{StaticResource TextOnlyButtonStyle}"
                                                        Click="ClearSearchUpcomingDate_Click">
                                                    <TextBlock Text="×"
                                                               FontSize="22" />
                                                </Button>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Attendance -->
                                        <StackPanel Grid.Row="8"
                                                    Grid.Column="0">
                                            <TextBlock Text="Attendance"
                                                       Style="{StaticResource FieldLabelStyle}" />
                                            <Grid>
                                                <ComboBox x:Name="SearchAttendanceBox"
                                                          Style="{StaticResource PopupComboBoxStyle}"
                                                          SelectedItem="{Binding SearchAttendance, UpdateSourceTrigger=Explicit}"
                                                          ItemsSource="{Binding AttendanceOptions}" />

                                                <Button Width="34"
                                                        Height="34"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0"
                                                        Style="{StaticResource TextOnlyButtonStyle}"
                                                        Click="ClearSearchAttendance_Click">
                                                    <TextBlock Text="×"
                                                               FontSize="22" />
                                                </Button>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Tag -->
                                        <StackPanel Grid.Row="8"
                                                    Grid.Column="2">
                                            <TextBlock Text="Tag"
                                                       Style="{StaticResource FieldLabelStyle}" />
                                            <Grid>
                                                <TextBox x:Name="SearchTagBox"
                                                         Style="{StaticResource SearchTextBoxStyle}"
                                                         Text="{Binding SearchTag, UpdateSourceTrigger=Explicit}" />

                                                <TextBlock Text="Example: Culture">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock"
                                                               BasedOn="{StaticResource PlaceholderBaseStyle}">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Text, ElementName=SearchTagBox}"
                                                                             Value="">
                                                                    <Setter Property="Visibility"
                                                                            Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <Button Width="34"
                                                        Height="34"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0"
                                                        Style="{StaticResource TextOnlyButtonStyle}"
                                                        Click="ClearSearchTag_Click">
                                                    <TextBlock Text="×"
                                                               FontSize="22" />
                                                </Button>
                                            </Grid>
                                        </StackPanel>

                                        <!-- Humanitarian -->
                                        <StackPanel Grid.Row="10"
                                                    Grid.Column="0"
                                                    Grid.ColumnSpan="3">
                                            <TextBlock Text="Humanitarian"
                                                       Style="{StaticResource FieldLabelStyle}" />

                                            <StackPanel Orientation="Horizontal">
                                                <RadioButton x:Name="SearchHumanitarianAny"
                                                             Content="Any"
                                                             GroupName="HumanitarianSearch"
                                                             IsChecked="{Binding SearchHumanitarianAny, UpdateSourceTrigger=Explicit}"
                                                             FontSize="16"
                                                             Margin="0,0,18,0" />

                                                <RadioButton x:Name="SearchHumanitarianYes"
                                                             Content="Yes"
                                                             GroupName="HumanitarianSearch"
                                                             IsChecked="{Binding SearchHumanitarianYes, UpdateSourceTrigger=Explicit}"
                                                             FontSize="16"
                                                             Margin="0,0,18,0" />

                                                <RadioButton x:Name="SearchHumanitarianNo"
                                                             Content="No"
                                                             GroupName="HumanitarianSearch"
                                                             IsChecked="{Binding SearchHumanitarianNo, UpdateSourceTrigger=Explicit}"
                                                             FontSize="16" />

                                                <Button Width="38"
                                                        Height="34"
                                                        Margin="18,0,0,0"
                                                        Style="{StaticResource TextOnlyButtonStyle}"
                                                        Click="ClearSearchHumanitarian_Click">
                                                    <TextBlock Text="×"
                                                               FontSize="22" />
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Actions -->
                                    <Grid Grid.Row="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="1"
                                                Content="Clear All"
                                                Width="120"
                                                Height="50"
                                                Background="#FFFFFF"
                                                BorderBrush="#C7D2E0"
                                                BorderThickness="1.5"
                                                FontSize="17"
                                                Cursor="Hand"
                                                Click="ClearAdvancedSearch_Click" />

                                        <Button Grid.Column="3"
                                                Width="150"
                                                Height="50"
                                                Background="#0E7EEC"
                                                BorderBrush="#0E7EEC"
                                                BorderThickness="1.5"
                                                Cursor="Hand"
                                                Click="ApplyAdvancedSearch_Click">

                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center">
                                                <fa:FontAwesome Icon="Search"
                                                                Foreground="White"
                                                                FontSize="22"
                                                                Margin="0,0,10,0"
                                                                VerticalAlignment="Center" />

                                                <TextBlock Text="Search"
                                                           Foreground="White"
                                                           FontSize="19"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Popup>
                    </Grid>
                </Border>

                <!-- Filter Events -->
                <Border x:Name="FilterEventsBorder"
                        Grid.Column="4"
                        Height="54"
                        Background="#FFFFFF"
                        BorderBrush="#C7D2E0"
                        BorderThickness="1.5"
                        CornerRadius="14">

                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background"
                                    Value="#FFFFFF" />
                            <Setter Property="BorderBrush"
                                    Value="#C7D2E0" />
                            <Setter Property="BorderThickness"
                                    Value="1.5" />

                            <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="#EEF6FF" />
                                    <Setter Property="BorderBrush"
                                            Value="#BFDFFF" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="52" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="Filter"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="27"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />

                        <Grid Grid.Column="1">
                            <TextBox x:Name="QuickFilterBox"
                                     Height="54"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="#1F2937"
                                     FontSize="17"
                                     FontWeight="SemiBold"
                                     Padding="0,-2,8,0"
                                     VerticalContentAlignment="Center"
                                     GotFocus="QuickFilterBox_GotFocus"
                                     LostFocus="QuickFilterBox_LostFocus"
                                     MouseEnter="QuickFilterBox_MouseEnter"
                                     MouseLeave="QuickFilterBox_MouseLeave"
                                     Text="{Binding EventSearchText, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="Filter Events..."
                                       Foreground="#9CA3AF"
                                       FontSize="17"
                                       FontWeight="Normal"
                                       VerticalAlignment="Center"
                                       TextAlignment="Left"
                                       Padding="0,1,0,0"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility"
                                                Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text.Length, ElementName=QuickFilterBox}"
                                                         Value="0">
                                                <Setter Property="Visibility"
                                                        Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <Button Grid.Column="2"
                                Width="32"
                                Height="32"
                                Cursor="Hand"
                                Click="ClearFilter_Click">

                            <Button.Style>
                                <Style TargetType="Button">

                                    <Setter Property="Visibility"
                                            Value="Visible" />

                                    <Setter Property="Foreground"
                                            Value="#6B7280" />

                                    <Setter Property="Background"
                                            Value="Transparent" />

                                    <Setter Property="BorderBrush"
                                            Value="Transparent" />

                                    <Setter Property="BorderThickness"
                                            Value="0" />

                                    <Setter Property="Template">
                                        <Setter.Value>

                                            <ControlTemplate TargetType="Button">

                                                <Border Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>

                                            </ControlTemplate>

                                        </Setter.Value>
                                    </Setter>

                                    <Style.Triggers>

                                        <DataTrigger Binding="{Binding Text.Length, ElementName=QuickFilterBox}"
                                                     Value="0">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                        </DataTrigger>

                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter Property="Foreground"
                                                    Value="#0968C7" />
                                        </Trigger>

                                    </Style.Triggers>

                                </Style>
                            </Button.Style>

                            <TextBlock Text="×"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                       FontSize="26"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="-10,-2,0,0" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <!-- Event table -->
            <Border Grid.Row="4"
                    Background="#FFFFFF"
                    BorderBrush="#E5EAF1"
                    BorderThickness="1"
                    CornerRadius="26"
                    Padding="0"
                    ClipToBounds="True">

                <Border.Effect>
                    <DropShadowEffect Color="#94A3B8"
                                      BlurRadius="24"
                                      ShadowDepth="3"
                                      Opacity="0.18" />
                </Border.Effect>

                <DataGrid Style="{StaticResource EventDataGridStyle}"
                          ItemsSource="{Binding EventsView}"
                          SelectedItem="{Binding SelectedEvent}"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">

                    <DataGrid.Resources>
                        <Style TargetType="ScrollBar"
                               BasedOn="{StaticResource ModernScrollBarStyle}" />
                    </DataGrid.Resources>

                    <DataGrid.Columns>

                        <DataGridTemplateColumn Header="Icon"
                                                Width="75">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <Grid Width="Auto"
                                          Height="44"
                                          ClipToBounds="True">

                                        <Image Source="{Binding IconPath, Converter={StaticResource ImagePathConverter}}"
                                               Width="44"
                                               Height="44"
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image.Clip>
                                                <RectangleGeometry Rect="0,0,44,44"
                                                                   RadiusX="10"
                                                                   RadiusY="10" />
                                            </Image.Clip>
                                        </Image>

                                    </Grid>

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="ID"
                                                Width="110">

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <Button Content="{Binding ID}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Foreground="#0E7EEC"
                                            FontSize="14"
                                            VerticalAlignment="Center"
                                            Click="ViewEvent_Click">

                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">

                                                <TextBlock Text="{TemplateBinding Content}"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           FontWeight="{TemplateBinding FontWeight}"
                                                           FontSize="{TemplateBinding FontSize}"
                                                           VerticalAlignment="Center" />

                                            </ControlTemplate>
                                        </Button.Template>

                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Foreground"
                                                        Value="#0E7EEC" />

                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver"
                                                             Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="#02419E" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>

                                    </Button>

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Name"
                                            Binding="{Binding Name}"
                                            Width="*" />

                        <DataGridTextColumn Header="Attendance"
                                            Binding="{Binding Attendance}"
                                            Width="*" />

                        <DataGridTextColumn Header="Type"
                                            Binding="{Binding EventTypeName}"
                                            Width="*" />

                        <DataGridTemplateColumn Header="Humanitarian?"
                                                Width="*">

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <Grid HorizontalAlignment="Center"
                                          VerticalAlignment="Center">

                                        <Border Width="18"
                                                Height="18"
                                                BorderBrush="#334155"
                                                BorderThickness="0.8"
                                                CornerRadius="9"
                                                Background="Transparent">

                                            <TextBlock Text="✓"
                                                       FontSize="12"
                                                       FontWeight="Bold"
                                                       Foreground="#334155"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Margin="0,-1,0,0">

                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed" />

                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsHumanitarian}"
                                                                         Value="True">
                                                                <Setter Property="Visibility"
                                                                        Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>

                                            </TextBlock>

                                        </Border>

                                    </Grid>

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Cost"
                                            Binding="{Binding Cost, StringFormat=${0:N1}}"
                                            Width="*" />

                        <DataGridTextColumn Header="Location"
                                            Binding="{Binding Location}"
                                            Width="*" />

                        <DataGridTextColumn Header="Date"
                                            Binding="{Binding UpcomingDate, StringFormat={}{0:dd.MM.yyyy}}"
                                            Width="*" />

                        <DataGridTemplateColumn Header=""
                                                Width="190"
                                                MinWidth="170"
                                                MaxWidth="190"
                                                CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Margin="0,0,10,0">

                                        <!-- VIEW -->
                                        <Button Width="50"
                                                Height="50"
                                                Margin="0,0,10,0"
                                                Style="{StaticResource TableViewButtonStyle}"
                                                Click="ViewEvent_Click"
                                                ToolTip="View Full Event">

                                            <fa:FontAwesome Icon="Eye"
                                                            FontSize="23"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center" />
                                        </Button>

                                        <!-- EDIT -->
                                        <Button Width="50"
                                                Height="50"
                                                Margin="0,0,10,0"
                                                Style="{StaticResource TableEditButtonStyle}"
                                                Click="EditEvent_Click"
                                                ToolTip="Edit Event">

                                            <fa:FontAwesome Icon="Pencil"
                                                            FontSize="23"
                                                            Foreground="White"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center" />
                                        </Button>

                                        <!-- DELETE -->
                                        <Button Width="50"
                                                Height="50"
                                                Style="{StaticResource TableDeleteButtonStyle}"
                                                Click="DeleteEvent_Click"
                                                ToolTip="Delete Event">

                                            <fa:FontAwesome Icon="Trash"
                                                            FontSize="23"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center" />
                                        </Button>

                                    </StackPanel>

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Popup x:Name="ViewEventPopup"
               PlacementTarget="{Binding ElementName=AdvancedSearchBorder}"
               Placement="Bottom"
               HorizontalOffset="0"
               VerticalOffset="11"
               AllowsTransparency="True"
               StaysOpen="False"
               PopupAnimation="Fade">

            <Border Width="474"
                    Height="650"
                    Background="#FFFFFF"
                    BorderBrush="#D6DFEA"
                    BorderThickness="1.5"
                    CornerRadius="18"
                    Padding="22">

                <Border.Effect>
                    <DropShadowEffect Color="#0F172A"
                                      BlurRadius="28"
                                      ShadowDepth="6"
                                      Opacity="0.20" />
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">

                        <Button Width="40"
                                Height="40"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Margin="0,-12,-13,0"
                                Click="CloseViewEventPopup_Click">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd"
                                            Background="Transparent"
                                            CornerRadius="10">
                                        <fa:FontAwesome Icon="Times"
                                                        Foreground="#1F2937"
                                                        FontSize="22"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="Bd"
                                                    Property="Background"
                                                    Value="#D6DFEA" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <Border Grid.Row="2"
                            Background="Transparent"
                            CornerRadius="18"
                            Padding="12"
                            Margin="0,-30,0,0">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="230" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Width="230"
                                    Height="150"
                                    BorderBrush="#D6DFEA"
                                    BorderThickness="2"
                                    Background="#FFFFFF"
                                    ClipToBounds="True">

                                <Image x:Name="ViewEventIconImage"
                                       Stretch="Fill"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>

                            <StackPanel Grid.Column="2"
                                        VerticalAlignment="Center">

                                <TextBlock x:Name="ViewEventNameTextBlock"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#0F172A"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8" />

                                <Border Background="#EAF2FF"
                                        BorderBrush="#BFDBFE"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="10,4"
                                        HorizontalAlignment="Left">

                                    <TextBlock x:Name="ViewEventIdTextBlock"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="#0E7EEC" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="#FFFFFF"
                                BorderBrush="#E5EAF1"
                                BorderThickness="1.3"
                                CornerRadius="14"
                                Padding="14,9">

                            <StackPanel>
                                <TextBlock Text="Description"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#64748B" />

                                <ScrollViewer MaxHeight="48"
                                              MinHeight="48"
                                              Margin="0,4,0,0"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">

                                    <ScrollViewer.Resources>
                                        <Style TargetType="ScrollBar"
                                               BasedOn="{StaticResource ModernScrollBarStyleMini}" />
                                    </ScrollViewer.Resources>

                                    <TextBlock x:Name="ViewEventDescriptionTextBlock"
                                               FontSize="15"
                                               Foreground="#0F172A"
                                               TextWrapping="Wrap" />
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="9" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="9" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Grid.Column="0"
                                    Background="#F8FBFF"
                                    BorderBrush="#E5EAF1"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="12,9">

                                <StackPanel>
                                    <TextBlock Text="Event Type"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#64748B" />

                                    <TextBlock x:Name="ViewEventTypeTextBlock"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="#0F172A"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="0"
                                    Grid.Column="2"
                                    Background="#F8FBFF"
                                    BorderBrush="#E5EAF1"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="12,9">

                                <StackPanel>
                                    <TextBlock Text="Location"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#64748B" />

                                    <TextBlock x:Name="ViewEventLocationTextBlock"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="#0F172A"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0"
                                               MaxHeight="36" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2"
                                    Grid.Column="0"
                                    Background="#F8FBFF"
                                    BorderBrush="#E5EAF1"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="12,9">

                                <StackPanel>
                                    <TextBlock Text="Upcoming Date"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#64748B" />

                                    <TextBlock x:Name="ViewEventUpcomingDateTextBlock"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="#0F172A"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2"
                                    Grid.Column="2"
                                    Background="#F8FBFF"
                                    BorderBrush="#E5EAF1"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="12,9">

                                <StackPanel>
                                    <TextBlock Text="Past Event Years"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#64748B" />

                                    <TextBlock x:Name="ViewEventPastYearsTextBlock"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="#0F172A"
                                               TextWrapping="Wrap"
                                               Margin="0,3,0,0"
                                               MaxHeight="36" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="4"
                                    Grid.Column="0"
                                    Background="#F8FBFF"
                                    BorderBrush="#E5EAF1"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="12,9">

                                <StackPanel>
                                    <TextBlock Text="Attendance"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#64748B" />

                                    <TextBlock x:Name="ViewEventAttendanceTextBlock"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="#0F172A"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="4"
                                    Grid.Column="2"
                                    Background="#F8FBFF"
                                    BorderBrush="#E5EAF1"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="12,9">

                                <StackPanel>
                                    <TextBlock Text="Humanitarian"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#64748B" />

                                    <TextBlock x:Name="ViewEventHumanitarianTextBlock"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="#0F172A"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="145" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="#FFFFFF"
                                    BorderBrush="#E5EAF1"
                                    BorderThickness="1.3"
                                    CornerRadius="14"
                                    Padding="14,9">

                                <StackPanel>
                                    <TextBlock Text="Event Tags"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#64748B" />

                                    <ScrollViewer MaxHeight="32"
                                                  Margin="0,6,0,0"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">

                                        <ScrollViewer.Resources>
                                            <Style TargetType="ScrollBar"
                                                   BasedOn="{StaticResource ModernScrollBarStyleMini}" />
                                        </ScrollViewer.Resources>

                                        <ItemsControl x:Name="ViewEventTagsItemsControl">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>

                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Height="28"
                                                            Background="#F8FBFF"
                                                            BorderBrush="#C7D2E0"
                                                            BorderThickness="1.5"
                                                            CornerRadius="14"
                                                            Padding="9,0"
                                                            Margin="0,0,8,6">

                                                        <StackPanel Orientation="Horizontal"
                                                                    VerticalAlignment="Center">
                                                            <Border Width="11"
                                                                    Height="11"
                                                                    CornerRadius="6"
                                                                    Background="{Binding Color}"
                                                                    Margin="0,0,7,0"
                                                                    VerticalAlignment="Center" />

                                                            <TextBlock Text="{Binding Description}"
                                                                       Foreground="#1F2937"
                                                                       FontSize="15"
                                                                       FontWeight="SemiBold"
                                                                       VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Background="#EAF2FF"
                                    BorderBrush="#0E7EEC"
                                    BorderThickness="1.5"
                                    CornerRadius="14"
                                    Padding="12,9">

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Cost"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#0E7EEC"
                                               HorizontalAlignment="Center" />

                                    <TextBlock x:Name="ViewEventCostTextBlock"
                                               FontSize="23"
                                               FontWeight="Bold"
                                               Foreground="#0F172A"
                                               HorizontalAlignment="Center"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Popup>


        <Grid x:Name="PopupOverlay"
              Background="#66000000"
              Visibility="Collapsed"
              Panel.ZIndex="9999"
              Grid.ColumnSpan="2" />


        <Border x:Name="DeleteConfirmPopup"
                Grid.ColumnSpan="2"
                Width="470"
                Background="White"
                BorderBrush="#D6DFEA"
                BorderThickness="2.5"
                CornerRadius="24"
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="Collapsed"
                Panel.ZIndex="10000">

            <StackPanel HorizontalAlignment="Center">

                <TextBlock Text="Are you sure you want to delete this event?"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#0F172A"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,0,0,22" />

                <Grid Margin="0,5,0,8">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Width="170"
                            Height="150"
                            BorderBrush="#D6DFEA"
                            BorderThickness="3">

                        <Image x:Name="DeleteEventIconImage"
                               Stretch="Fill" />
                    </Border>

                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center">

                        <TextBlock x:Name="DeleteEventNameTextBlock"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#0F172A"
                                   Margin="0,-5,0,16" />

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="95" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Event ID"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#64748B" />

                            <TextBlock x:Name="DeleteEventIdTextBlock"
                                       Grid.Column="1"
                                       FontSize="16"
                                       Foreground="#1F2937" />
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="95" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Type"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#64748B" />

                            <TextBlock x:Name="DeleteEventTypeTextBlock"
                                       Grid.Column="1"
                                       FontSize="16"
                                       Foreground="#1F2937" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="95" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Cost"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#64748B" />

                            <TextBlock x:Name="DeleteEventCostTextBlock"
                                       Grid.Column="1"
                                       FontSize="16"
                                       Foreground="#1F2937" />
                        </Grid>

                    </StackPanel>

                </Grid>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">

                    <Button Width="140"
                            Height="52"
                            Background="#FFFFFF"
                            BorderBrush="#C7D2E0"
                            BorderThickness="2"
                            Cursor="Hand"
                            Click="CancelDelete_Click"
                            Margin="0,20,14,0">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="14">

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">

                                        <fa:FontAwesome Icon="Times"
                                                        Foreground="#374151"
                                                        FontSize="22"
                                                        Margin="-5,2.5,10,0" />

                                        <TextBlock Text="Cancel"
                                                   FontSize="19"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1F2937"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter TargetName="Bd"
                                                Property="Background"
                                                Value="#F8FAFC" />

                                        <Setter TargetName="Bd"
                                                Property="BorderBrush"
                                                Value="#9DB7E8" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Width="140"
                            Height="52"
                            Background="{StaticResource AccentBrush}"
                            BorderBrush="#D6DFEA"
                            BorderThickness="2"
                            Cursor="Hand"
                            Margin="30,20,0,0"
                            Click="ConfirmDelete_Click">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="14">

                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">

                                        <fa:FontAwesome Icon="Trash"
                                                        Foreground="White"
                                                        FontSize="22"
                                                        Margin="0,2,10,0" />

                                        <TextBlock Text="Delete"
                                                   FontSize="19"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter TargetName="Bd"
                                                Property="Background"
                                                Value="#B91C1C" />

                                        <Setter TargetName="Bd"
                                                Property="BorderBrush"
                                                Value="#B91C1C" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border x:Name="ToastBorder"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Width="360"
                MinHeight="76"
                Background="#DCFCE7"
                BorderBrush="#22C55E"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,12"
                Margin="0,24,32,0"
                Visibility="Collapsed"
                Panel.ZIndex="10000">

            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  BlurRadius="16"
                                  ShadowDepth="3"
                                  Opacity="0.18" />
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="ToastIconCircle"
                        Grid.Column="0"
                        Width="28"
                        Height="28"
                        CornerRadius="14"
                        Background="#22C55E"
                        VerticalAlignment="Top"
                        Margin="0,9,0,0">

                    <fa:FontAwesome x:Name="ToastIcon"
                                    Icon="Check"
                                    Foreground="White"
                                    FontSize="14"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="8,0,0,0">

                    <TextBlock x:Name="ToastTitleTextBlock"
                               Text="SUCCESS"
                               Foreground="#166534"
                               FontSize="17"
                               FontWeight="Bold"
                               Margin="0,0,0,3" />

                    <TextBlock x:Name="ToastMessageTextBlock"
                               Text="Event saved successfully."
                               Foreground="#14532D"
                               FontSize="16"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>