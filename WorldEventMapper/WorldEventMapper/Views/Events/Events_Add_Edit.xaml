<Window x:Class="WorldEventMapper.Events.Events_Add_Edit"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        xmlns:models="clr-namespace:WorldEventMapper.Models"
        Title="Add New Event"
        Width="1400"
        Height="1070"
        Loaded="Window_Loaded"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackground"
                         Color="#F3F6FB" />
        <SolidColorBrush x:Key="PanelBackground"
                         Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBackgroundSoft"
                         Color="#EAF2FF" />
        <SolidColorBrush x:Key="BorderBrushColor"
                         Color="#D6DFEA" />
        <SolidColorBrush x:Key="AccentBrush"
                         Color="#0E7EEC" />
        <SolidColorBrush x:Key="AccentHoverBrush"
                         Color="#0968C7" />
        <SolidColorBrush x:Key="TextBrush"
                         Color="#0F172A" />
        <SolidColorBrush x:Key="MutedTextBrush"
                         Color="#6B7280" />

        <Style x:Key="ManagementButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#FFFFFF" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderBrush"
                    Value="#C7D2E0" />
            <Setter Property="BorderThickness"
                    Value="2" />
            <Setter Property="Padding"
                    Value="18,10" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="FontSize"
                    Value="17" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Height"
                    Value="60" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="8,4" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#F8FBFF" />
                                <Setter TargetName="Bd"
                                        Property="BorderBrush"
                                        Value="#9DB7E8" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#EAF2FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SaveButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="18,10" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="FontSize"
                    Value="18" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Height"
                    Value="58" />
            <Setter Property="Width"
                    Value="150" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#075AA8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ManagementButtonStyle}">
            <Setter Property="Width"
                    Value="150" />
            <Setter Property="Height"
                    Value="58" />
        </Style>

        <Style x:Key="ModernUploadButtonStyle"
               TargetType="Button">
            <Setter Property="Height"
                    Value="38" />
            <Setter Property="Width"
                    Value="150" />
            <Setter Property="Background"
                    Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="FontSize"
                    Value="15" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#075AA8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernDatePickerTextBoxStyle"
               TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="6,0,30,0" />
            <Setter Property="FontSize"
                    Value="16" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DatePickerTextBox}">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernDateInputStyle"
               TargetType="DatePicker">
            <Setter Property="Height"
                    Value="52" />
            <Setter Property="Background"
                    Value="#FFFFFF" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderBrush"
                    Value="#C7D2E0" />
            <Setter Property="BorderThickness"
                    Value="2" />
            <Setter Property="FontSize"
                    Value="16" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border x:Name="MainBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="52" />
                                </Grid.ColumnDefinitions>

                                <DatePickerTextBox x:Name="PART_TextBox"
                                                   Grid.Column="0"
                                                   Style="{StaticResource ModernDatePickerTextBoxStyle}"
                                                   IsReadOnly="True"
                                                   Focusable="False"
                                                   Cursor="Arrow" />

                                <Button x:Name="PART_Button"
                                        Grid.Column="1"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Focusable="False">

                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid Background="Transparent">
                                                <fa:FontAwesome Icon="Calendar"
                                                                Foreground="{StaticResource AccentBrush}"
                                                                FontSize="21"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center" />
                                            </Grid>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                       StaysOpen="False"
                                       PopupAnimation="Fade">

                                    <Border Background="#FFFFFF"
                                            BorderBrush="#D6DFEA"
                                            BorderThickness="1.5"
                                            CornerRadius="14"
                                            Padding="6"
                                            Margin="0,6,0,0"
                                            SnapsToDevicePixels="True">

                                        <Border.Effect>
                                            <DropShadowEffect Color="#000000"
                                                              BlurRadius="14"
                                                              ShadowDepth="3"
                                                              Opacity="0.16" />
                                        </Border.Effect>

                                        <Calendar x:Name="PART_Calendar"
                                                  Background="#FFFFFF"
                                                  BorderThickness="0"
                                                  Foreground="#1F2937"
                                                  FontSize="14" />
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="MainBorder"
                                        Property="BorderBrush"
                                        Value="#9DB7E8" />
                            </Trigger>

                            <Trigger Property="IsKeyboardFocusWithin"
                                     Value="True">
                                <Setter TargetName="MainBorder"
                                        Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ClearButtonStyle"
               TargetType="Button">
            <Setter Property="Width"
                    Value="34" />
            <Setter Property="Height"
                    Value="34" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="#6B7280" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="FontSize"
                    Value="24" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="HorizontalAlignment"
                    Value="Right" />
            <Setter Property="VerticalAlignment"
                    Value="Center" />
            <Setter Property="Margin"
                    Value="0,0,8,0" />
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Center" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              Margin="0,-2,0,0" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlaceholderTextStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="#9CA3AF" />
            <Setter Property="FontSize"
                    Value="16" />
            <Setter Property="Margin"
                    Value="16,0,48,0" />
            <Setter Property="VerticalAlignment"
                    Value="Center" />
            <Setter Property="IsHitTestVisible"
                    Value="False" />
            <Setter Property="Visibility"
                    Value="Collapsed" />
        </Style>

        <Style x:Key="FieldLabelStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="FontSize"
                    Value="17" />
            <Setter Property="Margin"
                    Value="0,0,0,8" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
        </Style>

        <Style x:Key="TextInputStyle"
               TargetType="TextBox">
            <Setter Property="Height"
                    Value="50" />
            <Setter Property="Background"
                    Value="#FFFFFF" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderBrush"
                    Value="#C7D2E0" />
            <Setter Property="BorderThickness"
                    Value="2" />
            <Setter Property="Padding"
                    Value="14,0,48,0" />
            <Setter Property="FontSize"
                    Value="16" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="MainBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">

                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="0,0,4,0"
                                          VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="MainBorder"
                                        Property="BorderBrush"
                                        Value="#9DB7E8" />
                            </Trigger>

                            <Trigger Property="IsKeyboardFocused"
                                     Value="True">
                                <Setter TargetName="MainBorder"
                                        Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernVerticalScrollBarStyle"
               TargetType="ScrollBar">
            <Setter Property="Width"
                    Value="3" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Opacity="0"
                                                  IsHitTestVisible="False" />
                                </Track.DecreaseRepeatButton>

                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#AFC3DA"
                                                        CornerRadius="2"
                                                        Margin="5,0,4,0" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>

                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Opacity="0"
                                                  IsHitTestVisible="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DescriptionInputStyle"
               TargetType="TextBox">
            <Setter Property="Height"
                    Value="92" />
            <Setter Property="Background"
                    Value="#FFFFFF" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderBrush"
                    Value="#C7D2E0" />
            <Setter Property="BorderThickness"
                    Value="2" />
            <Setter Property="FontSize"
                    Value="16" />
            <Setter Property="AcceptsReturn"
                    Value="True" />
            <Setter Property="TextWrapping"
                    Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility"
                    Value="Auto" />
            <Setter Property="VerticalContentAlignment"
                    Value="Top" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="MainBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">

                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="10,8,35,8"
                                          VerticalAlignment="Top"
                                          VerticalScrollBarVisibility="Auto">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar"
                                           BasedOn="{StaticResource ModernVerticalScrollBarStyle}" />
                                </ScrollViewer.Resources>
                            </ScrollViewer>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="MainBorder"
                                        Property="BorderBrush"
                                        Value="#9DB7E8" />
                            </Trigger>

                            <Trigger Property="IsKeyboardFocused"
                                     Value="True">
                                <Setter TargetName="MainBorder"
                                        Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboInputStyle"
               TargetType="ComboBox">
            <Setter Property="Height"
                    Value="50" />
            <Setter Property="Background"
                    Value="#FFFFFF" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderBrush"
                    Value="#C7D2E0" />
            <Setter Property="BorderThickness"
                    Value="2" />
            <Setter Property="FontSize"
                    Value="16" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
            <Setter Property="Padding"
                    Value="14,0,52,0" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="52" />
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter x:Name="ContentSite"
                                                      Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      Margin="14,0,8,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      IsHitTestVisible="False" />

                                    <TextBox x:Name="PART_EditableTextBox"
                                             Grid.Column="0"
                                             Margin="14,0,8,0"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{TemplateBinding Foreground}"
                                             FontSize="{TemplateBinding FontSize}"
                                             VerticalContentAlignment="Center"
                                             Visibility="Hidden"
                                             IsReadOnly="{TemplateBinding IsReadOnly}" />

                                    <ToggleButton x:Name="ToggleButton"
                                                  Grid.Column="1"
                                                  Focusable="False"
                                                  Cursor="Hand"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">

                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Grid Background="Transparent">
                                                    <fa:FontAwesome Icon="ChevronDown"
                                                                    Foreground="{StaticResource AccentBrush}"
                                                                    FontSize="16"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center" />
                                                </Grid>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Slide">

                                <Border Background="White"
                                        BorderBrush="#C7D2E0"
                                        BorderThickness="1.5"
                                        CornerRadius="12"
                                        Margin="0,6,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">

                                    <ScrollViewer MaxHeight="180"
                                                  Padding="4"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ScrollViewer.Resources>
                                            <Style TargetType="ScrollBar"
                                                   BasedOn="{StaticResource ModernVerticalScrollBarStyle}" />
                                        </ScrollViewer.Resources>

                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="MainBorder"
                                        Property="BorderBrush"
                                        Value="#9DB7E8" />
                            </Trigger>

                            <Trigger Property="IsKeyboardFocusWithin"
                                     Value="True">
                                <Setter TargetName="MainBorder"
                                        Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}" />
                            </Trigger>

                            <Trigger Property="IsEditable"
                                     Value="True">
                                <Setter TargetName="ContentSite"
                                        Property="Visibility"
                                        Value="Hidden" />
                                <Setter TargetName="PART_EditableTextBox"
                                        Property="Visibility"
                                        Value="Visible" />
                            </Trigger>

                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="MainBorder"
                                        Property="Opacity"
                                        Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding"
                    Value="12,8" />
            <Setter Property="FontSize"
                    Value="15" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="Background"
                    Value="Transparent" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#EAF2FF" />
                            </Trigger>

                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#DCEEFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DateInputStyle"
               TargetType="DatePicker">
            <Setter Property="Height"
                    Value="50" />
            <Setter Property="Background"
                    Value="#FFFFFF" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderBrush"
                    Value="#C7D2E0" />
            <Setter Property="BorderThickness"
                    Value="2" />
            <Setter Property="FontSize"
                    Value="16" />
        </Style>

        <Style x:Key="CheckBoxStyleAccessible"
               TargetType="CheckBox">
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="FontSize"
                    Value="16" />
            <Setter Property="VerticalAlignment"
                    Value="Center" />
        </Style>


        <Style x:Key="ModernListBoxStyle"
               TargetType="ListBox">
            <Setter Property="Background"
                    Value="#FFFFFF" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderBrush"
                    Value="#C7D2E0" />
            <Setter Property="BorderThickness"
                    Value="2" />
            <Setter Property="Padding"
                    Value="6,4,48,4" />
            <Setter Property="FontSize"
                    Value="15" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border x:Name="MainBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">

                            <ScrollViewer Padding="{TemplateBinding Padding}"
                                          VerticalScrollBarVisibility="Auto">
                                <ScrollViewer.Resources>
                                    <Style TargetType="ScrollBar"
                                           BasedOn="{StaticResource ModernVerticalScrollBarStyle}" />
                                </ScrollViewer.Resources>

                                <ItemsPresenter />
                            </ScrollViewer>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="MainBorder"
                                        Property="BorderBrush"
                                        Value="#9DB7E8" />
                            </Trigger>

                            <Trigger Property="IsKeyboardFocusWithin"
                                     Value="True">
                                <Setter TargetName="MainBorder"
                                        Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HumanitarianBulletStyle"
               TargetType="primitives:ToggleButton">
            <Setter Property="Height"
                    Value="50" />
            <Setter Property="MinWidth"
                    Value="80" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderBrush"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="FontSize"
                    Value="16" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Cursor"
                    Value="Hand" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="primitives:ToggleButton">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border x:Name="BulletOuter"
                                        Grid.Column="0"
                                        Width="17"
                                        Height="17"
                                        CornerRadius="9"
                                        BorderBrush="#9CA3AF"
                                        BorderThickness="2"
                                        Background="White"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Margin="0,0,8,0">

                                    <Border x:Name="BulletInner"
                                            Width="8"
                                            Height="8"
                                            CornerRadius="4"
                                            Background="Transparent"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                                </Border>

                                <ContentPresenter Grid.Column="1"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  Margin="2,0,0,0" />
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="BulletOuter"
                                        Property="BorderBrush"
                                        Value="#9DB7E8" />
                                <Setter Property="Foreground"
                                        Value="#0E7EEC" />
                            </Trigger>

                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Setter TargetName="BulletOuter"
                                        Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="BulletInner"
                                        Property="Background"
                                        Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground"
                                        Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RequiredFieldLabelStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="FontSize"
                    Value="17" />
            <Setter Property="Margin"
                    Value="0,0,0,8" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
        </Style>

    </Window.Resources>

    <Grid>
        <Border Width="1060"
                Height="720"
                Background="White"
                CornerRadius="28"
                Padding="28"
                BorderBrush="#D6DFEA"
                BorderThickness="1.5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="TitleTextBlock"
                               Text="Add New Event"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#0F172A"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />

                    <Button Grid.Column="1"
                            Width="42"
                            Height="42"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Close_Click">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="Transparent"
                                        CornerRadius="10">

                                    <fa:FontAwesome Icon="Times"
                                                    Foreground="#1F2937"
                                                    FontSize="22"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center" />
                                </Border>

                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter TargetName="Bd"
                                                Property="Background"
                                                Value="#D6DFEA" />
                                    </Trigger>

                                    <Trigger Property="IsPressed"
                                             Value="True">
                                        <Setter TargetName="Bd"
                                                Property="Background"
                                                Value="#D6DFEA" />
                                    </Trigger>

                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Form -->
                <Border Grid.Row="2"
                        Padding="10,15,10,0">

                    <ScrollViewer VerticalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="18" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="24" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- LEFT COLUMN -->

                            <StackPanel Grid.Row="0"
                                        Grid.Column="0">
                                <TextBlock Style="{StaticResource RequiredFieldLabelStyle}">
                     <Run Text="Event ID" />
                     <Run Text="*"
                                    Foreground="#DC2626"
                                    FontWeight="Bold"
                                    FontSize="17" />
                                </TextBlock>

                                <Grid>
                                    <TextBox x:Name="EventIdTextBox"
                                             Style="{StaticResource TextInputStyle}" />

                                    <TextBlock Text="Enter event ID">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock"
                                                   BasedOn="{StaticResource PlaceholderTextStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=EventIdTextBox}"
                                                                 Value="">
                                                        <Setter Property="Visibility"
                                                                Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Button Content="×"
                                            Click="ClearEventId_Click">
                                        <Button.Style>
                                            <Style TargetType="Button"
                                                   BasedOn="{StaticResource ClearButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text.Length, ElementName=EventIdTextBox}"
                                                                 Value="0">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Row="2"
                                        Grid.Column="0">
                                <TextBlock Style="{StaticResource RequiredFieldLabelStyle}">
                     <Run Text="Event Name" />
                     <Run Text="*"
                                    Foreground="#DC2626"
                                    FontWeight="Bold"
                                    FontSize="17" />
                                </TextBlock>

                                <Grid>
                                    <TextBox x:Name="EventNameTextBox"
                                             Style="{StaticResource TextInputStyle}" />

                                    <TextBlock Text="Enter event name">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock"
                                                   BasedOn="{StaticResource PlaceholderTextStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=EventNameTextBox}"
                                                                 Value="">
                                                        <Setter Property="Visibility"
                                                                Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Button Content="×"
                                            Click="ClearEventName_Click">
                                        <Button.Style>
                                            <Style TargetType="Button"
                                                   BasedOn="{StaticResource ClearButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text.Length, ElementName=EventNameTextBox}"
                                                                 Value="0">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Row="4"
                                        Grid.Column="0">
                                <TextBlock Text="Event Description"
                                           Style="{StaticResource FieldLabelStyle}" />

                                <Grid>
                                    <TextBox x:Name="DescriptionTextBox"
                                             Style="{StaticResource DescriptionInputStyle}" />

                                    <TextBlock Text="Write a short event description">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock"
                                                   BasedOn="{StaticResource PlaceholderTextStyle}">
                                                <Setter Property="VerticalAlignment"
                                                        Value="Top" />
                                                <Setter Property="Margin"
                                                        Value="16,12,48,0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=DescriptionTextBox}"
                                                                 Value="">
                                                        <Setter Property="Visibility"
                                                                Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Button Content="×"
                                            Click="ClearDescription_Click">
                                        <Button.Style>
                                            <Style TargetType="Button"
                                                   BasedOn="{StaticResource ClearButtonStyle}">
                                                <Setter Property="VerticalAlignment"
                                                        Value="Top" />
                                                <Setter Property="Margin"
                                                        Value="0,29,8,0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text.Length, ElementName=DescriptionTextBox}"
                                                                 Value="0">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <Grid Grid.Row="6"
                                  Grid.Column="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource RequiredFieldLabelStyle}">
                         <Run Text="Event Type" />
                         <Run Text="*"
                                        Foreground="#DC2626"
                                        FontWeight="Bold"
                                        FontSize="17" />
                                    </TextBlock>

                                    <Grid>
                                        <ComboBox x:Name="EventTypeComboBox"
                                                  Style="{StaticResource ComboInputStyle}"
                                                  SelectionChanged="EventTypeComboBox_SelectionChanged">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate DataType="{x:Type models:EventTypeModel}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Text="  " />
                                                        <TextBlock Text="{Binding ID}"
                                                                   Foreground="#6B7280" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>

                                        <TextBlock Text="Click to select a type">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock"
                                                       BasedOn="{StaticResource PlaceholderTextStyle}">
                                                    <Setter Property="Margin"
                                                            Value="16,-1,52,0" />

                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedItem, ElementName=EventTypeComboBox}"
                                                                     Value="{x:Null}">
                                                            <Setter Property="Visibility"
                                                                    Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Button Content="×"
                                                Click="ClearEventType_Click">
                                            <Button.Style>
                                                <Style TargetType="Button"
                                                       BasedOn="{StaticResource ClearButtonStyle}">
                                                    <Setter Property="Margin"
                                                            Value="0,0,35,0" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedItem, ElementName=EventTypeComboBox}"
                                                                     Value="{x:Null}">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="2">

                                    <TextBlock Style="{StaticResource RequiredFieldLabelStyle}">
                         <Run Text="Event Attendance" />
                         <Run Text="*"
                                        Foreground="#DC2626"
                                        FontWeight="Bold"
                                        FontSize="17" />
                                    </TextBlock>

                                    <Grid>
                                        <ComboBox x:Name="AttendanceComboBox"
                                                  Style="{StaticResource ComboInputStyle}" />

                                        <Button Content="×"
                                                Click="ClearAttendance_Click">
                                            <Button.Style>
                                                <Style TargetType="Button"
                                                       BasedOn="{StaticResource ClearButtonStyle}">
                                                    <Setter Property="Margin"
                                                            Value="0,0,35,0" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedItem, ElementName=AttendanceComboBox}"
                                                                     Value="{x:Null}">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="8"
                                        Grid.Column="0">
                                <TextBlock Text="Event Icon"
                                           Style="{StaticResource FieldLabelStyle}" />

                                <Border Height="92"
                                        Background="#F8FBFF"
                                        BorderBrush="#C7D2E0"
                                        BorderThickness="2"
                                        CornerRadius="16"
                                        Padding="10">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="78" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="42" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="74"
                                                Height="68"
                                                Background="#FFFFFF"
                                                CornerRadius="12"
                                                BorderBrush="#D6DFEA"
                                                BorderThickness="1.5"
                                                VerticalAlignment="Center">

                                            <Grid>
                                                <Image x:Name="SelectedImagePreview"
                                                       Stretch="Uniform"
                                                       Margin="0" />

                                                <fa:FontAwesome x:Name="ImagePlaceholderIcon"
                                                                Icon="Image"
                                                                Foreground="#9CA3AF"
                                                                FontSize="24"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Margin="10,0,0,0">

                                            <TextBlock x:Name="ImagePathTextBlock"
                                                       Text="Upload event image"
                                                       Foreground="#1F2937"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="420"
                                                       Margin="0,0,20,8" />

                                            <Button Style="{StaticResource ModernUploadButtonStyle}"
                                                    HorizontalAlignment="Left"
                                                    Click="UploadImage_Click">

                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center">

                                                    <fa:FontAwesome Icon="Upload"
                                                                    FontSize="16"
                                                                    Margin="0,0,8,0"
                                                                    VerticalAlignment="Center" />

                                                    <TextBlock Text="Choose image"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>

                                        <Button Grid.Column="2"
                                                Content="×"
                                                Click="ClearImage_Click">
                                            <Button.Style>
                                                <Style TargetType="Button"
                                                       BasedOn="{StaticResource ClearButtonStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=ImagePathTextBlock}"
                                                                     Value="Upload event image">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!-- RIGHT COLUMN -->

                            <Grid Grid.Row="0"
                                  Grid.Column="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Humanitarian Event?"
                                               Style="{StaticResource FieldLabelStyle}" />

                                    <Grid Height="50">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <primitives:ToggleButton x:Name="HumanitarianYesToggle"
                                                                 Grid.Column="0"
                                                                 Content="Yes"
                                                                 Style="{StaticResource HumanitarianBulletStyle}"
                                                                 Checked="HumanitarianYesToggle_Checked" />

                                        <primitives:ToggleButton x:Name="HumanitarianNoToggle"
                                                                 Grid.Column="2"
                                                                 Content="No"
                                                                 Style="{StaticResource HumanitarianBulletStyle}"
                                                                 Checked="HumanitarianNoToggle_Checked" />
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource RequiredFieldLabelStyle}">
                         <Run Text="$ Event Cost" />
                         <Run Text="*"
                                        Foreground="#DC2626"
                                        FontWeight="Bold"
                                        FontSize="17" />
                                    </TextBlock>

                                    <Grid>
                                        <TextBox x:Name="CostTextBox"
                                                 Style="{StaticResource TextInputStyle}"
                                                 PreviewTextInput="CostTextBox_PreviewTextInput"
                                                 TextChanged="CostTextBox_TextChanged"
                                                 DataObject.Pasting="CostTextBox_Pasting" />

                                        <TextBlock Text="$0.00">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock"
                                                       BasedOn="{StaticResource PlaceholderTextStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=CostTextBox}"
                                                                     Value="">
                                                            <Setter Property="Visibility"
                                                                    Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Button Content="×"
                                                Click="ClearCost_Click">
                                            <Button.Style>
                                                <Style TargetType="Button"
                                                       BasedOn="{StaticResource ClearButtonStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text.Length, ElementName=CostTextBox}"
                                                                     Value="0">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="2"
                                        Grid.Column="2">
                                <TextBlock Style="{StaticResource RequiredFieldLabelStyle}">
                     <Run Text="Event Location" />
                     <Run Text="*"
                                    Foreground="#DC2626"
                                    FontWeight="Bold"
                                    FontSize="17" />
                                </TextBlock>

                                <Grid>
                                    <ComboBox x:Name="LocationComboBox"
                                              Style="{StaticResource ComboInputStyle}"
                                              IsEditable="True"
                                              IsTextSearchEnabled="False"
                                              StaysOpenOnEdit="True"
                                              Loaded="LocationComboBox_Loaded" />

                                    <TextBlock Text="Enter or select a location">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock"
                                                   BasedOn="{StaticResource PlaceholderTextStyle}">
                                                <Setter Property="Margin"
                                                        Value="16,0,52,0" />

                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=LocationComboBox}"
                                                                 Value="">
                                                        <Setter Property="Visibility"
                                                                Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Button Content="×"
                                            Click="ClearLocation_Click">
                                        <Button.Style>
                                            <Style TargetType="Button"
                                                   BasedOn="{StaticResource ClearButtonStyle}">
                                                <Setter Property="Margin"
                                                        Value="0,0,35,0" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text.Length, ElementName=LocationComboBox}"
                                                                 Value="0">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Row="4"
                                        Grid.Column="2">
                                <TextBlock Text="Event Tags"
                                           Style="{StaticResource FieldLabelStyle}" />

                                <Grid>
                                    <ListBox x:Name="TagsListBox"
                                             Height="92"
                                             SelectionMode="Multiple"
                                             BorderBrush="#C7D2E0"
                                             BorderThickness="2"
                                             Background="#FFFFFF"
                                             Padding="0"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                                        <ListBox.Resources>
                                            <Style TargetType="ScrollBar"
                                                   BasedOn="{StaticResource ModernVerticalScrollBarStyle}" />
                                        </ListBox.Resources>

                                        <ListBox.Template>
                                            <ControlTemplate TargetType="ListBox">
                                                <Border x:Name="MainBorder"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="12">

                                                    <Grid>
                                                        <ScrollViewer x:Name="TagsScrollViewer"
                                                                      Margin="10,8,46,8"
                                                                      MaxHeight="72"
                                                                      VerticalAlignment="Center"
                                                                      VerticalScrollBarVisibility="Auto"
                                                                      HorizontalScrollBarVisibility="Disabled"
                                                                      CanContentScroll="False">

                                                            <ItemsPresenter VerticalAlignment="Center" />
                                                        </ScrollViewer>
                                                    </Grid>
                                                </Border>

                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver"
                                                             Value="True">
                                                        <Setter TargetName="MainBorder"
                                                                Property="BorderBrush"
                                                                Value="#9DB7E8" />
                                                    </Trigger>

                                                    <Trigger Property="IsKeyboardFocusWithin"
                                                             Value="True">
                                                        <Setter TargetName="MainBorder"
                                                                Property="BorderBrush"
                                                                Value="{StaticResource AccentBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ListBox.Template>

                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"
                                                           Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                                           VerticalAlignment="Center" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>

                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Margin"
                                                        Value="0,0,8,6" />
                                                <Setter Property="Padding"
                                                        Value="0" />
                                                <Setter Property="Height"
                                                        Value="28" />
                                                <Setter Property="Background"
                                                        Value="Transparent" />
                                                <Setter Property="BorderThickness"
                                                        Value="0" />
                                                <Setter Property="Cursor"
                                                        Value="Hand" />
                                                <Setter Property="VerticalContentAlignment"
                                                        Value="Center" />

                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="TagChip"
                                                                    Height="28"
                                                                    Background="#F8FBFF"
                                                                    BorderBrush="#C7D2E0"
                                                                    BorderThickness="1.5"
                                                                    CornerRadius="14"
                                                                    Padding="9,0"
                                                                    VerticalAlignment="Center">

                                                                <StackPanel Orientation="Horizontal"
                                                                            VerticalAlignment="Center">
                                                                    <Border Width="11"
                                                                            Height="11"
                                                                            CornerRadius="6"
                                                                            Background="{Binding Color}"
                                                                            Margin="0,0,7,0"
                                                                            VerticalAlignment="Center" />

                                                                    <TextBlock Text="{Binding Description}"
                                                                               Foreground="#1F2937"
                                                                               FontSize="16"
                                                                               FontWeight="SemiBold"
                                                                               VerticalAlignment="Center" />

                                                                    <fa:FontAwesome x:Name="SelectedIcon"
                                                                                    Icon="Check"
                                                                                    Foreground="#0E7EEC"
                                                                                    FontSize="12"
                                                                                    Margin="4,1,0,0"
                                                                                    VerticalAlignment="Center"
                                                                                    Visibility="Collapsed" />
                                                                </StackPanel>
                                                            </Border>

                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver"
                                                                         Value="True">
                                                                    <Setter TargetName="TagChip"
                                                                            Property="Background"
                                                                            Value="#EEF6FF" />
                                                                    <Setter TargetName="TagChip"
                                                                            Property="BorderBrush"
                                                                            Value="#9DB7E8" />
                                                                </Trigger>

                                                                <Trigger Property="IsSelected"
                                                                         Value="True">
                                                                    <Setter TargetName="TagChip"
                                                                            Property="Background"
                                                                            Value="#EAF2FF" />
                                                                    <Setter TargetName="TagChip"
                                                                            Property="BorderBrush"
                                                                            Value="#0E7EEC" />
                                                                    <Setter TargetName="SelectedIcon"
                                                                            Property="Visibility"
                                                                            Value="Visible" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>

                                    <Button Content="×"
                                            Click="ClearTags_Click">
                                        <Button.Style>
                                            <Style TargetType="Button"
                                                   BasedOn="{StaticResource ClearButtonStyle}">
                                                <Setter Property="VerticalAlignment"
                                                        Value="Top" />
                                                <Setter Property="HorizontalAlignment"
                                                        Value="Right" />
                                                <Setter Property="Margin"
                                                        Value="0,29,8,0" />
                                                <Setter Property="Panel.ZIndex"
                                                        Value="10" />

                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedIndex, ElementName=TagsListBox}"
                                                                 Value="-1">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <Grid Grid.Row="6"
                                  Grid.Column="2"
                                  Grid.ColumnSpan="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Event Past Performing Years"
                                               Style="{StaticResource FieldLabelStyle}" />

                                    <Grid>
                                        <TextBox x:Name="PastYearsTextBox"
                                                 Style="{StaticResource TextInputStyle}"
                                                 PreviewTextInput="PastYearsTextBox_PreviewTextInput"
                                                 TextChanged="PastYearsTextBox_TextChanged"
                                                 DataObject.Pasting="PastYearsTextBox_Pasting" />

                                        <TextBlock Text="Enter years, e.g. 2020,2021,2022">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock"
                                                       BasedOn="{StaticResource PlaceholderTextStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=PastYearsTextBox}"
                                                                     Value="">
                                                            <Setter Property="Visibility"
                                                                    Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Button Content="×"
                                                Click="ClearYears_Click">
                                            <Button.Style>
                                                <Style TargetType="Button"
                                                       BasedOn="{StaticResource ClearButtonStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text.Length, ElementName=PastYearsTextBox}"
                                                                     Value="0">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource RequiredFieldLabelStyle}">
                         <Run Text="Event Upcoming Date" />
                         <Run Text="*"
                                        Foreground="#DC2626"
                                        FontWeight="Bold"
                                        FontSize="17" />
                                    </TextBlock>

                                    <Grid>
                                        <DatePicker x:Name="UpcomingDatePicker"
                                                    Style="{StaticResource ModernDateInputStyle}" />

                                        <TextBlock Text="mm/dd/yyyy"
                                                   Margin="16,0,95,0"
                                                   Foreground="#9CA3AF"
                                                   FontSize="16"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedDate, ElementName=UpcomingDatePicker}"
                                                                     Value="{x:Null}">
                                                            <Setter Property="Visibility"
                                                                    Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Button Content="×"
                                                Click="ClearDate_Click">
                                            <Button.Style>
                                                <Style TargetType="Button"
                                                       BasedOn="{StaticResource ClearButtonStyle}">
                                                    <Setter Property="Margin"
                                                            Value="0,0,54,0" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SelectedDate, ElementName=UpcomingDatePicker}"
                                                                     Value="{x:Null}">
                                                            <Setter Property="Visibility"
                                                                    Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Grid>


                            <!-- SAVE ROW -->
                            <StackPanel Grid.Row="8"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="3"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,60,0,0">

                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        Click="ClearAll_Click"
                                        Margin="0,3,14,0">
                                    <StackPanel Orientation="Horizontal">
                                        <fa:FontAwesome Icon="Trash"
                                                        FontSize="20"
                                                        Margin="0,0,10,0"
                                                        VerticalAlignment="Center" />

                                        <TextBlock Text="Clear All"
                                                   VerticalAlignment="Center"
                                                   FontSize="19" />
                                    </StackPanel>
                                </Button>

                                <Button Style="{StaticResource SaveButtonStyle}"
                                        Click="SaveEvent_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <fa:FontAwesome Icon="Save"
                                                        FontSize="20"
                                                        Margin="0,0,10,0"
                                                        VerticalAlignment="Center" />

                                        <TextBlock Text="Save"
                                                   VerticalAlignment="Center"
                                                   FontSize="21" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="ToastBorder"
                Width="360"
                MinHeight="76"
                Background="#FEE2E2"
                BorderBrush="#FCA5A5"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,12"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,135,0,0"
                Visibility="Collapsed"
                Panel.ZIndex="99999">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="34" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="ToastIconCircle"
                        Grid.Column="0"
                        Width="28"
                        Height="28"
                        CornerRadius="14"
                        Background="#EF4444"
                        VerticalAlignment="Top"
                        Margin="0,9,0,0">

                    <fa:FontAwesome x:Name="ToastIcon"
                                    Icon="Exclamation"
                                    Foreground="White"
                                    FontSize="14"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1"
                            Margin="8,0,0,0">

                    <TextBlock x:Name="ToastTitleTextBlock"
                               Text="ERROR"
                               Foreground="#991B1B"
                               FontSize="17"
                               FontWeight="Bold"
                               Margin="0,0,0,3" />

                    <TextBlock x:Name="ToastMessageTextBlock"
                               Text="Validation error."
                               Foreground="#7F1D1D"
                               FontSize="16"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>