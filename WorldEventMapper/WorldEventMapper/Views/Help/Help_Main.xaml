<Window x:Class="WorldEventMapper.Help.Help_Main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="Help Center"
        Height="900"
        Width="1250"
        WindowStartupLocation="CenterScreen"
        Background="#F7F9FC"
        WindowState="Maximized"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackground"
                         Color="#F3F6FB" />
        <SolidColorBrush x:Key="PanelBackground"
                         Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushColor"
                         Color="#D6DFEA" />
        <SolidColorBrush x:Key="AccentBrush"
                         Color="#0E7EEC" />
        <SolidColorBrush x:Key="TextBrush"
                         Color="#0F172A" />
        <SolidColorBrush x:Key="MutedTextBrush"
                         Color="#6B7280" />

        <Style x:Key="NavButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderBrush"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="18,0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="FontSize"
                    Value="18" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Height"
                    Value="58" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#EEF6FF" />
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#E0F0FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActiveNavButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background"
                    Value="#EAF2FF" />
            <Setter Property="BorderBrush"
                    Value="#D6E8FF" />
            <Setter Property="BorderThickness"
                    Value="1" />
        </Style>

        <Style x:Key="TopHelpButtonStyle"
               TargetType="Button">
            <Setter Property="Width"
                    Value="120" />
            <Setter Property="Height"
                    Value="54" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                CornerRadius="12"
                                Padding="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#EEF6FF" />
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#E0F0FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#FFFFFF" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderBrush"
                    Value="#C7D2E0" />
            <Setter Property="BorderThickness"
                    Value="1.5" />
            <Setter Property="Padding"
                    Value="16,10" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="FontSize"
                    Value="18" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Height"
                    Value="54" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="8,4" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#EEF6FF" />
                                <Setter TargetName="Bd"
                                        Property="BorderBrush"
                                        Value="#BFDFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#E0F0FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="0,0,1.5,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="138" />
                    <RowDefinition Height="70" />
                    <RowDefinition Height="70" />
                    <RowDefinition Height="70" />
                    <RowDefinition Height="70" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="80" />
                </Grid.RowDefinitions>

                <!-- Logo -->
                <Border Grid.Row="0"
                        BorderBrush="#E5ECF5"
                        BorderThickness="0,0,0,1"
                        Padding="0">

                    <Button Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Home_Click"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">

                        <Grid HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch">

                            <Border Width="720"
                                    Height="720"
                                    Background="White"
                                    CornerRadius="36"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                                <Image Source="/Assets/logo.png"
                                       Width="200"
                                       Height="200"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>
                        </Grid>
                    </Button>
                </Border>

                <!-- Home -->
                <Button Grid.Row="1"
                        Style="{StaticResource NavButtonStyle}"
                        Margin="18,10,18,0"
                        Click="Home_Click">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="Home"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        VerticalAlignment="Center"
                                        Margin="-20,0,0,0" />

                        <TextBlock Grid.Column="1"
                                   Text="Home"
                                   Foreground="#1F2937"
                                   FontSize="19"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <!-- Event List -->
                <Button Grid.Row="2"
                        Style="{StaticResource NavButtonStyle}"
                        Margin="18,8,18,0"
                        Click="EventList_Click">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="List"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        VerticalAlignment="Center"
                                        Margin="-20,5,0,0" />

                        <TextBlock Grid.Column="1"
                                   Text="Event List"
                                   Foreground="#1F2937"
                                   FontSize="19"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <!-- Event Management -->
                <Button Grid.Row="3"
                        Style="{StaticResource NavButtonStyle}"
                        Margin="18,8,18,0"
                        Click="EventManagement_Click">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="Edit"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        VerticalAlignment="Center"
                                        Margin="-20,5,0,0" />

                        <TextBlock Grid.Column="1"
                                   Text="Event Management"
                                   Foreground="#1F2937"
                                   FontSize="18"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <!-- Help active -->
                <Button Grid.Row="4"
                        Style="{StaticResource ActiveNavButtonStyle}"
                        Margin="18,8,18,0">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="QuestionCircle"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        VerticalAlignment="Center"
                                        Margin="-20,5,0,0" />

                        <TextBlock Grid.Column="1"
                                   Text="Help"
                                   Foreground="#1F2937"
                                   FontSize="19"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <!-- Logout -->
                <Button Grid.Row="6"
                        Style="{StaticResource NavButtonStyle}"
                        Height="58"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        Margin="18,0,18,0"
                        Click="CloseToMain_Click">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="SignOut"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        VerticalAlignment="Center"
                                        Margin="-20,5,0,0" />

                        <TextBlock Grid.Column="1"
                                   Text="Logout"
                                   Foreground="#1F2937"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Column="1"
              Margin="32,20,32,32">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Help Center"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="42"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />

                <Button Grid.Column="1"
                        Style="{StaticResource TopHelpButtonStyle}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                        <Border Width="42"
                                Height="42"
                                Background="#0E7EEC"
                                CornerRadius="21"
                                Margin="0,0,6,0">

                            <TextBlock Text="?"
                                       Foreground="White"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Text="Help"
                                   Foreground="#0E7EEC"
                                   FontSize="19"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Action row -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Style="{StaticResource RoundedButtonStyle}"
                        Width="210">

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <fa:FontAwesome Icon="Refresh"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="22"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Center" />

                        <TextBlock Text="Retake App Tour"
                                   FontSize="18"
                                   Foreground="#1F2937"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <CheckBox Grid.Column="2"
                          Content="Disable ToolTips"
                          Foreground="#1F2937"
                          FontSize="18"
                          FontWeight="SemiBold"
                          VerticalAlignment="Center" />
            </Grid>

            <!-- Help content -->
            <Border Grid.Row="4"
                    Background="#FFFFFF"
                    BorderBrush="#D6DFEA"
                    BorderThickness="1.5"
                    CornerRadius="16"
                    Padding="30">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="30" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="30" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Left 1 -->
                    <StackPanel Grid.Row="0"
                                Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <fa:FontAwesome Icon="QuestionCircle"
                                            Foreground="#1F2937"
                                            FontSize="22"
                                            Margin="0,0,10,0" />
                            <TextBlock Text="How to Add Events?"
                                       Foreground="#1F2937"
                                       FontSize="20"
                                       FontWeight="Bold" />
                        </StackPanel>

                        <TextBlock Text="→ Go to Event Management from the left navigation bar"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,10,0,0" />
                        <TextBlock Text="→ Click Add Event"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,4,0,0" />
                        <TextBlock Text="→ Add the required details"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,4,0,0" />
                        <TextBlock Text="→ Click Save"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,4,0,0" />
                    </StackPanel>

                    <!-- Right 1 -->
                    <StackPanel Grid.Row="0"
                                Grid.Column="2">
                        <StackPanel Orientation="Horizontal">
                            <fa:FontAwesome Icon="QuestionCircle"
                                            Foreground="#1F2937"
                                            FontSize="22"
                                            Margin="0,0,10,0" />
                            <TextBlock Text="How to Edit or Delete Events?"
                                       Foreground="#1F2937"
                                       FontSize="20"
                                       FontWeight="Bold" />
                        </StackPanel>

                        <TextBlock Text="→ Go to Event Management"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,10,0,0" />
                        <TextBlock Text="→ Select the event you want to change"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,4,0,0" />
                        <TextBlock Text="→ Update the fields or click Delete"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,4,0,0" />
                        <TextBlock Text="→ Save your changes"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,4,0,0" />
                    </StackPanel>

                    <!-- Left 2 -->
                    <StackPanel Grid.Row="2"
                                Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <fa:FontAwesome Icon="QuestionCircle"
                                            Foreground="#1F2937"
                                            FontSize="22"
                                            Margin="0,0,10,0" />
                            <TextBlock Text="How to Filter in the Event List?"
                                       Foreground="#1F2937"
                                       FontSize="20"
                                       FontWeight="Bold" />
                        </StackPanel>

                        <TextBlock Text="→ Open Event List"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,10,0,0" />
                        <TextBlock Text="→ Type in the filter field"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,4,0,0" />
                        <TextBlock Text="→ The table updates automatically"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,4,0,0" />
                        <TextBlock Text="→ Clear the field to show all events"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,4,0,0" />
                    </StackPanel>

                    <!-- Right 2 -->
                    <StackPanel Grid.Row="2"
                                Grid.Column="2">
                        <StackPanel Orientation="Horizontal">
                            <fa:FontAwesome Icon="QuestionCircle"
                                            Foreground="#1F2937"
                                            FontSize="22"
                                            Margin="0,0,10,0" />
                            <TextBlock Text="How to Search for my Event?"
                                       Foreground="#1F2937"
                                       FontSize="20"
                                       FontWeight="Bold" />
                        </StackPanel>

                        <TextBlock Text="→ Open Event List"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,10,0,0" />
                        <TextBlock Text="→ Use the search box at the top"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,4,0,0" />
                        <TextBlock Text="→ Search by name, ID, location, type, or tag"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,4,0,0" />
                        <TextBlock Text="→ Select the matching event in the table"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,4,0,0" />
                    </StackPanel>

                    <!-- Left 3 -->
                    <StackPanel Grid.Row="4"
                                Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <fa:FontAwesome Icon="QuestionCircle"
                                            Foreground="#1F2937"
                                            FontSize="22"
                                            Margin="0,0,10,0" />
                            <TextBlock Text="How to Add/Filter Events on the Map?"
                                       Foreground="#1F2937"
                                       FontSize="20"
                                       FontWeight="Bold" />
                        </StackPanel>

                        <TextBlock Text="→ Go to Home"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,10,0,0" />
                        <TextBlock Text="→ Filter events on the right side"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,4,0,0" />
                        <TextBlock Text="→ Drag an event onto the map"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,4,0,0" />
                        <TextBlock Text="→ Right-click a pin to remove it"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,4,0,0" />
                    </StackPanel>

                    <!-- Right 3 -->
                    <StackPanel Grid.Row="4"
                                Grid.Column="2">
                        <StackPanel Orientation="Horizontal">
                            <fa:FontAwesome Icon="QuestionCircle"
                                            Foreground="#1F2937"
                                            FontSize="22"
                                            Margin="0,0,10,0" />
                            <TextBlock Text="How to turn off ToolTips?"
                                       Foreground="#1F2937"
                                       FontSize="20"
                                       FontWeight="Bold" />
                        </StackPanel>

                        <TextBlock Text="→ Open Help Center"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,10,0,0" />
                        <TextBlock Text="→ Find Disable ToolTips at the top right"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,4,0,0" />
                        <TextBlock Text="→ Check the box"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,4,0,0" />
                        <TextBlock Text="→ Uncheck it to enable ToolTips again"
                                   Foreground="#1F2937"
                                   FontSize="16"
                                   Margin="30,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>