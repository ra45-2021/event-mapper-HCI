<Window x:Class="WorldEventMapper.Event_Management.EventManagement_Main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:models="clr-namespace:WorldEventMapper.Models"
        Title="Event Management"
        Height="900"
        Width="1250"
        WindowStartupLocation="CenterScreen"
        Background="#F7F9FC"
        WindowState="Maximized"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackground"
                         Color="#F3F6FB" />
        <SolidColorBrush x:Key="PanelBackground"
                         Color="#FFFFFF" />
        <SolidColorBrush x:Key="PanelBackgroundSoft"
                         Color="#EAF2FF" />
        <SolidColorBrush x:Key="BorderBrushColor"
                         Color="#D6DFEA" />
        <SolidColorBrush x:Key="AccentBrush"
                         Color="#0E7EEC" />
        <SolidColorBrush x:Key="AccentHoverBrush"
                         Color="#0968C7" />
        <SolidColorBrush x:Key="TextBrush"
                         Color="#0F172A" />
        <SolidColorBrush x:Key="MutedTextBrush"
                         Color="#6B7280" />

        <Style x:Key="NavButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderBrush"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="18,0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="FontSize"
                    Value="18" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Height"
                    Value="58" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#EEF6FF" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#E0F0FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActiveNavButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background"
                    Value="#EAF2FF" />
            <Setter Property="BorderBrush"
                    Value="#D6E8FF" />
            <Setter Property="BorderThickness"
                    Value="1" />
        </Style>

        <Style x:Key="TopHelpButtonStyle"
               TargetType="Button">
            <Setter Property="Width"
                    Value="120" />
            <Setter Property="Height"
                    Value="54" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                CornerRadius="12"
                                Padding="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#EEF6FF" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#E0F0FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ManagementButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#FFFFFF" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderBrush"
                    Value="#C7D2E0" />
            <Setter Property="BorderThickness"
                    Value="2" />
            <Setter Property="Padding"
                    Value="18,10" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="FontSize"
                    Value="17" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Height"
                    Value="60" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="8,4" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#F8FBFF" />
                                <Setter TargetName="Bd"
                                        Property="BorderBrush"
                                        Value="#9DB7E8" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#EAF2FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SaveButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="18,10" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="FontSize"
                    Value="18" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Height"
                    Value="58" />
            <Setter Property="Width"
                    Value="150" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#075AA8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ManagementButtonStyle}">
            <Setter Property="Width"
                    Value="150" />
            <Setter Property="Height"
                    Value="58" />
        </Style>

        <Style x:Key="ModernUploadButtonStyle"
               TargetType="Button">
            <Setter Property="Height"
                    Value="38" />
            <Setter Property="Width"
                    Value="150" />
            <Setter Property="Background"
                    Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="FontSize"
                    Value="15" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="Bd"
                                        Property="Background"
                                        Value="#075AA8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernDatePickerTextBoxStyle"
               TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="14,0,48,0" />
            <Setter Property="FontSize"
                    Value="16" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DatePickerTextBox}">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernDateInputStyle"
               TargetType="DatePicker">
            <Setter Property="Height"
                    Value="52" />
            <Setter Property="Background"
                    Value="#FFFFFF" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderBrush"
                    Value="#C7D2E0" />
            <Setter Property="BorderThickness"
                    Value="2" />
            <Setter Property="FontSize"
                    Value="16" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border x:Name="MainBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="52" />
                                </Grid.ColumnDefinitions>

                                <DatePickerTextBox x:Name="PART_TextBox"
                                                   Grid.Column="0"
                                                   Style="{StaticResource ModernDatePickerTextBoxStyle}" />

                                <Button x:Name="PART_Button"
                                        Grid.Column="1"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Focusable="False">

                                    <Border Width="36"
                                            Height="36"
                                            Background="#EAF2FF"
                                            CornerRadius="10"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">

                                        <fa:FontAwesome Icon="Calendar"
                                                        Foreground="{StaticResource AccentBrush}"
                                                        FontSize="19"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                                    </Border>
                                </Button>

                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                       StaysOpen="False" />
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="MainBorder"
                                        Property="BorderBrush"
                                        Value="#9DB7E8" />
                            </Trigger>

                            <Trigger Property="IsKeyboardFocusWithin"
                                     Value="True">
                                <Setter TargetName="MainBorder"
                                        Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ClearButtonStyle"
               TargetType="Button">
            <Setter Property="Width"
                    Value="34" />
            <Setter Property="Height"
                    Value="34" />
            <Setter Property="Background"
                    Value="Transparent" />
            <Setter Property="Foreground"
                    Value="#6B7280" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="FontSize"
                    Value="24" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="HorizontalAlignment"
                    Value="Right" />
            <Setter Property="VerticalAlignment"
                    Value="Center" />
            <Setter Property="Margin"
                    Value="0,0,8,0" />
            <Setter Property="Padding"
                    Value="0" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Center" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              Margin="0,-2,0,0" />
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlaceholderTextStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="#9CA3AF" />
            <Setter Property="FontSize"
                    Value="16" />
            <Setter Property="Margin"
                    Value="16,0,48,0" />
            <Setter Property="VerticalAlignment"
                    Value="Center" />
            <Setter Property="IsHitTestVisible"
                    Value="False" />
            <Setter Property="Visibility"
                    Value="Collapsed" />
        </Style>

        <Style x:Key="FieldLabelStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="FontSize"
                    Value="17" />
            <Setter Property="Margin"
                    Value="0,0,0,8" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
        </Style>

        <Style x:Key="TextInputStyle"
               TargetType="TextBox">
            <Setter Property="Height"
                    Value="50" />
            <Setter Property="Background"
                    Value="#FFFFFF" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderBrush"
                    Value="#C7D2E0" />
            <Setter Property="BorderThickness"
                    Value="2" />
            <Setter Property="Padding"
                    Value="14,8,48,8" />
            <Setter Property="FontSize"
                    Value="16" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
        </Style>

        <Style x:Key="ComboInputStyle"
               TargetType="ComboBox">
            <Setter Property="Height"
                    Value="50" />
            <Setter Property="Background"
                    Value="#FFFFFF" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderBrush"
                    Value="#C7D2E0" />
            <Setter Property="BorderThickness"
                    Value="2" />
            <Setter Property="Padding"
                    Value="10,6" />
            <Setter Property="FontSize"
                    Value="16" />
        </Style>

        <Style x:Key="DateInputStyle"
               TargetType="DatePicker">
            <Setter Property="Height"
                    Value="50" />
            <Setter Property="Background"
                    Value="#FFFFFF" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="BorderBrush"
                    Value="#C7D2E0" />
            <Setter Property="BorderThickness"
                    Value="2" />
            <Setter Property="FontSize"
                    Value="16" />
        </Style>

        <Style x:Key="CheckBoxStyleAccessible"
               TargetType="CheckBox">
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="FontSize"
                    Value="16" />
            <Setter Property="VerticalAlignment"
                    Value="Center" />
        </Style>
        <Style x:Key="ModernCalendarStyle"
               TargetType="Calendar">
            <Setter Property="Background"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#C7D2E0" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Padding"
                    Value="10" />
            <Setter Property="FontSize"
                    Value="15" />
            <Setter Property="Foreground"
                    Value="#1F2937" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000"
                                      BlurRadius="18"
                                      ShadowDepth="4"
                                      Opacity="0.18" />
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrushColor}"
                BorderThickness="0,0,1.5,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="138" />
                    <RowDefinition Height="70" />
                    <RowDefinition Height="70" />
                    <RowDefinition Height="70" />
                    <RowDefinition Height="70" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="80" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        BorderBrush="#E5ECF5"
                        BorderThickness="0,0,0,1"
                        Padding="0">

                    <Button Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="Home_Click"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch">

                        <Grid HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch">

                            <Border Width="720"
                                    Height="720"
                                    Background="White"
                                    CornerRadius="36"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                                <Image Source="/Assets/logo.png"
                                       Width="200"
                                       Height="200"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       RenderOptions.BitmapScalingMode="HighQuality" />
                            </Border>
                        </Grid>
                    </Button>
                </Border>

                <Button Grid.Row="1"
                        Style="{StaticResource NavButtonStyle}"
                        Margin="18,10,18,0"
                        Click="Home_Click">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="Home"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        VerticalAlignment="Center"
                                        Margin="-20,0,0,0" />

                        <TextBlock Grid.Column="1"
                                   Text="Home"
                                   Foreground="#1F2937"
                                   FontSize="19"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <Button Grid.Row="2"
                        Style="{StaticResource NavButtonStyle}"
                        Margin="18,8,18,0"
                        Click="EventList_Click">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="List"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        VerticalAlignment="Center"
                                        Margin="-20,5,0,0" />

                        <TextBlock Grid.Column="1"
                                   Text="Event List"
                                   Foreground="#1F2937"
                                   FontSize="19"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <Button Grid.Row="3"
                        Style="{StaticResource ActiveNavButtonStyle}"
                        Margin="18,8,18,0">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="Edit"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        VerticalAlignment="Center"
                                        Margin="-20,5,0,0" />

                        <TextBlock Grid.Column="1"
                                   Text="Event Management"
                                   Foreground="#1F2937"
                                   FontSize="18"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <Button Grid.Row="4"
                        Style="{StaticResource NavButtonStyle}"
                        Margin="18,8,18,0"
                        Click="Help_Click">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="QuestionCircle"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        VerticalAlignment="Center"
                                        Margin="-20,5,0,0" />

                        <TextBlock Grid.Column="1"
                                   Text="Help"
                                   Foreground="#1F2937"
                                   FontSize="19"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <Button Grid.Row="6"
                        Style="{StaticResource NavButtonStyle}"
                        Height="58"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        Margin="18,0,18,0"
                        Click="CloseToMain_Click">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="SignOut"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        VerticalAlignment="Center"
                                        Margin="-20,5,0,0" />

                        <TextBlock Grid.Column="1"
                                   Text="Logout"
                                   Foreground="#1F2937"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Column="1"
              Margin="32,20,32,32">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="24" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Event Management"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="42"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />

                <Button Grid.Column="1"
                        Style="{StaticResource TopHelpButtonStyle}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="Help_Click">

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                        <Border Width="42"
                                Height="42"
                                Background="#0E7EEC"
                                CornerRadius="21"
                                Margin="0,0,6,0">

                            <TextBlock Text="?"
                                       Foreground="White"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Text="Help"
                                   Foreground="#0E7EEC"
                                   FontSize="19"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Top action buttons -->
            <UniformGrid Grid.Row="2"
                         Columns="4">

                <Button Style="{StaticResource ManagementButtonStyle}"
                        Margin="0,0,14,0"
                        Click="NewEvent_Click">

                    <Grid HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="PlusCircle"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />

                        <TextBlock Grid.Column="1"
                                   Text="New Event"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,2" />
                    </Grid>
                </Button>

                <Button Style="{StaticResource ManagementButtonStyle}"
                        Margin="0,0,14,0"
                        Click="ManageEvents_Click">

                    <Grid HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="Edit"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />

                        <TextBlock Grid.Column="1"
                                   Text="Manage Events"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,2" />
                    </Grid>
                </Button>

                <Button Style="{StaticResource ManagementButtonStyle}"
                        Margin="0,0,14,0"
                        Click="ManageTags_Click">

                    <Grid HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="Tag"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />

                        <TextBlock Grid.Column="1"
                                   Text="Manage Tags"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,2" />
                    </Grid>
                </Button>

                <Button Style="{StaticResource ManagementButtonStyle}"
                        Click="ManageTypes_Click">

                    <Grid HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <fa:FontAwesome Grid.Column="0"
                                        Icon="ThLarge"
                                        Foreground="{StaticResource AccentBrush}"
                                        FontSize="30"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />

                        <TextBlock Grid.Column="1"
                                   Text="Manage Event Types"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,2" />
                    </Grid>
                </Button>

            </UniformGrid>

            <!-- Form -->
            <Border Grid.Row="4"
                    Background="{StaticResource PanelBackground}"
                    BorderBrush="{StaticResource BorderBrushColor}"
                    BorderThickness="2"
                    CornerRadius="20"
                    Padding="28">

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="18" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- LEFT COLUMN -->

                        <StackPanel Grid.Row="0"
                                    Grid.Column="0">
                            <TextBlock Text="Event ID"
                                       Style="{StaticResource FieldLabelStyle}" />

                            <Grid>
                                <TextBox x:Name="EventIdTextBox"
                                         Style="{StaticResource TextInputStyle}" />

                                <TextBlock Text="Enter event ID">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock"
                                               BasedOn="{StaticResource PlaceholderTextStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=EventIdTextBox}"
                                                             Value="">
                                                    <Setter Property="Visibility"
                                                            Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Button Content="×"
                                        Click="ClearEventId_Click">
                                    <Button.Style>
                                        <Style TargetType="Button"
                                               BasedOn="{StaticResource ClearButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text.Length, ElementName=EventIdTextBox}"
                                                             Value="0">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Grid.Column="0">
                            <TextBlock Text="Event Name"
                                       Style="{StaticResource FieldLabelStyle}" />

                            <Grid>
                                <TextBox x:Name="EventNameTextBox"
                                         Style="{StaticResource TextInputStyle}" />

                                <TextBlock Text="Enter event name">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock"
                                               BasedOn="{StaticResource PlaceholderTextStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=EventNameTextBox}"
                                                             Value="">
                                                    <Setter Property="Visibility"
                                                            Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Button Content="×"
                                        Click="ClearEventName_Click">
                                    <Button.Style>
                                        <Style TargetType="Button"
                                               BasedOn="{StaticResource ClearButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text.Length, ElementName=EventNameTextBox}"
                                                             Value="0">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="4"
                                    Grid.Column="0">
                            <TextBlock Text="Event Description"
                                       Style="{StaticResource FieldLabelStyle}" />

                            <Grid>
                                <TextBox x:Name="DescriptionTextBox"
                                         Style="{StaticResource TextInputStyle}"
                                         Height="92"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         VerticalContentAlignment="Top"
                                         Padding="14,12,48,8" />

                                <TextBlock Text="Write a short event description">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock"
                                               BasedOn="{StaticResource PlaceholderTextStyle}">
                                            <Setter Property="VerticalAlignment"
                                                    Value="Top" />
                                            <Setter Property="Margin"
                                                    Value="16,12,48,0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=DescriptionTextBox}"
                                                             Value="">
                                                    <Setter Property="Visibility"
                                                            Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Button Content="×"
                                        Click="ClearDescription_Click">
                                    <Button.Style>
                                        <Style TargetType="Button"
                                               BasedOn="{StaticResource ClearButtonStyle}">
                                            <Setter Property="VerticalAlignment"
                                                    Value="Top" />
                                            <Setter Property="Margin"
                                                    Value="0,8,8,0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text.Length, ElementName=DescriptionTextBox}"
                                                             Value="0">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="6"
                                    Grid.Column="0">
                            <TextBlock Text="Event Type"
                                       Style="{StaticResource FieldLabelStyle}" />

                            <Grid>
                                <ComboBox x:Name="EventTypeComboBox"
                                          Style="{StaticResource ComboInputStyle}"
                                          SelectionChanged="EventTypeComboBox_SelectionChanged">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:EventTypeModel}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="  " />
                                                <TextBlock Text="{Binding ID}"
                                                           Foreground="#6B7280" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <Button Content="×"
                                        Click="ClearEventType_Click">
                                    <Button.Style>
                                        <Style TargetType="Button"
                                               BasedOn="{StaticResource ClearButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedItem, ElementName=EventTypeComboBox}"
                                                             Value="{x:Null}">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="8"
                                    Grid.Column="0">
                            <TextBlock Text="Event Attendance"
                                       Style="{StaticResource FieldLabelStyle}" />

                            <Grid>
                                <ComboBox x:Name="AttendanceComboBox"
                                          Style="{StaticResource ComboInputStyle}" />

                                <Button Content="×"
                                        Click="ClearAttendance_Click">
                                    <Button.Style>
                                        <Style TargetType="Button"
                                               BasedOn="{StaticResource ClearButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedItem, ElementName=AttendanceComboBox}"
                                                             Value="{x:Null}">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <Grid Grid.Row="10"
                              Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Is the Event Humanitarian?"
                                           Style="{StaticResource FieldLabelStyle}" />

                                <Grid Height="50">
                                    <Border Background="White"
                                            BorderBrush="#C7D2E0"
                                            BorderThickness="2" />

                                    <CheckBox x:Name="HumanitarianCheckBox"
                                              Style="{StaticResource CheckBoxStyleAccessible}"
                                              Content="Yes"
                                              Margin="14,0,48,0"
                                              VerticalAlignment="Center" />

                                    <Button Content="×"
                                            Click="ClearHumanitarian_Click">
                                        <Button.Style>
                                            <Style TargetType="Button"
                                                   BasedOn="{StaticResource ClearButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsChecked, ElementName=HumanitarianCheckBox}"
                                                                 Value="False">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Event Cost"
                                           Style="{StaticResource FieldLabelStyle}" />

                                <Grid>
                                    <TextBox x:Name="CostTextBox"
                                             Style="{StaticResource TextInputStyle}" />

                                    <TextBlock Text="Enter cost, e.g. 15000">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock"
                                                   BasedOn="{StaticResource PlaceholderTextStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=CostTextBox}"
                                                                 Value="">
                                                        <Setter Property="Visibility"
                                                                Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Button Content="×"
                                            Click="ClearCost_Click">
                                        <Button.Style>
                                            <Style TargetType="Button"
                                                   BasedOn="{StaticResource ClearButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text.Length, ElementName=CostTextBox}"
                                                                 Value="0">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!-- RIGHT COLUMN -->

                        <StackPanel Grid.Row="0"
                                    Grid.Column="2">
                            <TextBlock Text="Event Icon"
                                       Style="{StaticResource FieldLabelStyle}" />

                            <Border Height="132"
                                    Background="#F8FBFF"
                                    BorderBrush="#C7D2E0"
                                    BorderThickness="2"
                                    CornerRadius="16"
                                    Padding="14">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="96" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="42" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="82"
                                            Height="82"
                                            Background="#FFFFFF"
                                            CornerRadius="14"
                                            BorderBrush="#D6DFEA"
                                            BorderThickness="1.5"
                                            VerticalAlignment="Center">

                                        <Grid>
                                            <Image x:Name="SelectedImagePreview"
                                                   Stretch="Uniform"
                                                   Margin="7" />

                                            <fa:FontAwesome Icon="Image"
                                                            Foreground="#9CA3AF"
                                                            FontSize="28"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Margin="12,0,0,0">

                                        <TextBlock Text="Upload event image"
                                                   Foreground="#1F2937"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />

                                        <TextBlock x:Name="ImagePathTextBlock"
                                                   Text="No image selected. Type icon will be used."
                                                   Foreground="#6B7280"
                                                   FontSize="14"
                                                   TextWrapping="Wrap"
                                                   Margin="0,3,0,0" />

                                        <Button Style="{StaticResource ModernUploadButtonStyle}"
                                                Margin="0,10,0,0"
                                                HorizontalAlignment="Left"
                                                Click="UploadImage_Click">

                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">

                                                <fa:FontAwesome Icon="Upload"
                                                                FontSize="16"
                                                                Margin="0,0,8,0"
                                                                VerticalAlignment="Center" />

                                                <TextBlock Text="Choose image"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <Button Grid.Column="2"
                                            Content="×"
                                            Click="ClearImage_Click">
                                        <Button.Style>
                                            <Style TargetType="Button"
                                                   BasedOn="{StaticResource ClearButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=ImagePathTextBlock}"
                                                                 Value="No image selected. Type icon will be used.">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Grid.Column="2">
                            <TextBlock Text="Event Past Performing Years"
                                       Style="{StaticResource FieldLabelStyle}" />

                            <Grid>
                                <TextBox x:Name="PastYearsTextBox"
                                         Style="{StaticResource TextInputStyle}" />

                                <TextBlock Text="Enter years, e.g. 2020,2021,2022">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock"
                                               BasedOn="{StaticResource PlaceholderTextStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=PastYearsTextBox}"
                                                             Value="">
                                                    <Setter Property="Visibility"
                                                            Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Button Content="×"
                                        Click="ClearYears_Click">
                                    <Button.Style>
                                        <Style TargetType="Button"
                                               BasedOn="{StaticResource ClearButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text.Length, ElementName=PastYearsTextBox}"
                                                             Value="0">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="4"
                                    Grid.Column="2">
                            <TextBlock Text="Event Upcoming Date"
                                       Style="{StaticResource FieldLabelStyle}" />

                            <Grid>
                                <DatePicker x:Name="UpcomingDatePicker"
                                            Style="{StaticResource ModernDateInputStyle}" />

                                <TextBlock Text="Select upcoming event date"
                                           Margin="16,0,95,0"
                                           Foreground="#9CA3AF"
                                           FontSize="16"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility"
                                                    Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedDate, ElementName=UpcomingDatePicker}"
                                                             Value="{x:Null}">
                                                    <Setter Property="Visibility"
                                                            Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Button Content="×"
                                        Click="ClearDate_Click">
                                    <Button.Style>
                                        <Style TargetType="Button"
                                               BasedOn="{StaticResource ClearButtonStyle}">
                                            <Setter Property="Margin"
                                                    Value="0,0,54,0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedDate, ElementName=UpcomingDatePicker}"
                                                             Value="{x:Null}">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="6"
                                    Grid.Column="2">
                            <TextBlock Text="Event Location"
                                       Style="{StaticResource FieldLabelStyle}" />

                            <Grid>
                                <ComboBox x:Name="LocationComboBox"
                                          Style="{StaticResource ComboInputStyle}"
                                          IsEditable="True" />

                                <Button Content="×"
                                        Click="ClearLocation_Click">
                                    <Button.Style>
                                        <Style TargetType="Button"
                                               BasedOn="{StaticResource ClearButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text.Length, ElementName=LocationComboBox}"
                                                             Value="0">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Row="8"
                                    Grid.Column="2"
                                    Grid.RowSpan="3">
                            <TextBlock Text="Event Tags"
                                       Style="{StaticResource FieldLabelStyle}" />

                            <Grid>
                                <ListBox x:Name="TagsListBox"
                                         Height="170"
                                         SelectionMode="Multiple"
                                         BorderBrush="#C7D2E0"
                                         BorderThickness="2"
                                         Background="White"
                                         Padding="6,4,48,4">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:EventTagModel}">
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="8,6">
                                                <Border Width="18"
                                                        Height="18"
                                                        CornerRadius="5"
                                                        Background="{Binding Color}"
                                                        Margin="0,0,10,0" />

                                                <TextBlock Text="{Binding Description}"
                                                           Foreground="#6B7280"
                                                           FontSize="15" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Button Content="×"
                                        Click="ClearTags_Click">
                                    <Button.Style>
                                        <Style TargetType="Button"
                                               BasedOn="{StaticResource ClearButtonStyle}">
                                            <Setter Property="VerticalAlignment"
                                                    Value="Top" />
                                            <Setter Property="Margin"
                                                    Value="0,8,8,0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedIndex, ElementName=TagsListBox}"
                                                             Value="-1">
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <!-- SAVE ROW -->
                        <StackPanel Grid.Row="12"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="3"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,10,0,0">

                            <Button Content="Clear All"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,14,0"
                                    Click="ClearAll_Click" />

                            <Button Style="{StaticResource SaveButtonStyle}"
                                    Click="SaveEvent_Click">
                                <StackPanel Orientation="Horizontal">
                                    <fa:FontAwesome Icon="Save"
                                                    FontSize="20"
                                                    Margin="0,0,10,0"
                                                    VerticalAlignment="Center" />

                                    <TextBlock Text="Save"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>