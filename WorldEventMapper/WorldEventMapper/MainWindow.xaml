<Window x:Class="WorldEventMapper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="World Event Mapper"
        Height="900"
        Width="1250"
        WindowStartupLocation="CenterScreen"
        Background="#F3F6FB"
        WindowState="Maximized"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="ModernActionButton" TargetType="Button">
            <Setter Property="Width" Value="780"/>
            <Setter Property="Height" Value="92"/>
            <Setter Property="Padding" Value="28,0"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D6DFEA"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="24"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18"
                                                  ShadowDepth="3"
                                                  Opacity="0.10"/>
                            </Border.Effect>
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F8FBFF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#8CB4FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EAF2FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButton" TargetType="Button" BasedOn="{StaticResource ModernActionButton}">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="24"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20"
                                                  ShadowDepth="4"
                                                  Opacity="0.16"/>
                            </Border.Effect>
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E40AF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="60">

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

<Image Source="/map.png"
       Opacity="0.06"
       Stretch="UniformToFill"
       IsHitTestVisible="False"
       Panel.ZIndex="0"/>

        <!-- Title -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center">
            <TextBlock Text="Welcome to"
                       Foreground="#4B5563"
                       FontWeight="SemiBold"
                       FontSize="26"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>

            <TextBlock Text="WORLD EVENT MAPPER"
                       Foreground="#111827"
                       FontWeight="ExtraBold"
                       FontSize="64"
                       Margin="0,8,0,0"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>
        </StackPanel>

        <!-- Subtitle -->
        <TextBlock Grid.Row="2"
                   Text="Explore, organize, and experience world events through a cleaner and easier interface."
                   Foreground="#6B7280"
                   FontSize="20"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   HorizontalAlignment="Center"
                   MaxWidth="700"
                   Margin="0,24,0,0"/>

        <!-- Button 1 -->
        <Button Grid.Row="6"
                Style="{StaticResource ModernActionButton}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <fa:FontAwesome Icon="MapOutline"
                                Foreground="#2563EB"
                                Width="31"
                                Height="24"
                                Margin="0,0,16,0"
                                VerticalAlignment="Center"/>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Take a quick app tour"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>
                    <TextBlock Text="Best for first-time users"
                               FontSize="15"
                               Foreground="#6B7280"/>
                </StackPanel>
            </StackPanel>
        </Button>

        <!-- Button 2 -->
        <Button Grid.Row="4"
                Style="{StaticResource PrimaryActionButton}"
                Click="GoToHomePage_Click">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <fa:FontAwesome Icon="ArrowRight"
                                Foreground="White"
                                Width="22"
                                Height="22"
                                Margin="0,0,16,0"
                                VerticalAlignment="Center"/>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Enter the application"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </Button>
    </Grid>
</Window>